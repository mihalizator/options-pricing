\section{Transformations to a semilinear heat equation}
\label{sec:transform}

We reduce the nonlinear Black--Scholes equation~\eqref{eq:nonlinearBS}
to a semilinear heat equation via four successive changes of variables,
each detailed in a dedicated subsection below.
\subsection{Time-to-maturity and discounting}
\label{sec:discount}

We set $\tau=T-t$, so we can tranform the backwards pricing problem into a forward parabolic equation. We also introduce a discounted unknown, which removes the zeroth-order discounting term $U(\tau,S)$. These are standard steps in
the analysis of Black--Scholes-type equations; see, for example,
\cite[Ch.~4]{WilmottHowisonDewynne1995}.

Let $\tau=T-t$ (so $\tau\in(0,\infty)$) and define the discounted unknown
\[
U(\tau,S):=e^{r\tau}V(T-\tau,S)=e^{r(T-t)}V(t,S).
\]
We compute the derivatives of \(V\) in terms of \(U\).

\medskip
\noindent\textbf{Time derivative.}
Since \(\tau=T-t\), we have
\[
\frac{d\tau}{dt}=-1.
\]
Using the chain rule,
\begin{align*}
V_t(t,S)
&=
\frac{\partial}{\partial t}\bigl(e^{-r\tau}U(\tau,S)\bigr)\\
&=
\frac{\partial}{\partial \tau}\bigl(e^{-r\tau}U(\tau,S)\bigr)\cdot \frac{d\tau}{dt}\\
&=
\bigl(-r e^{-r\tau}U+e^{-r\tau}U_\tau\bigr)(-1)\\
&=
e^{-r\tau}(rU-U_\tau).
\end{align*}
Therefore
\begin{equation}
\boxed{
V_t=e^{-r\tau}(rU-U_\tau).
}
\label{eq:Vt_from_U}
\end{equation}

\medskip
\noindent\textbf{Spatial derivatives.}
Since the factor \(e^{-r\tau}\) does not depend on \(S\),
\[
V_{S_i}=e^{-r\tau}U_{S_i},
\qquad
V_{S_iS_j}=e^{-r\tau}U_{S_iS_j}.
\]
Hence
\begin{equation}
\boxed{
V_{S_i}=e^{-r\tau}U_{S_i},
\qquad
V_{S_iS_j}=e^{-r\tau}U_{S_iS_j}.
}
\label{eq:spatial_from_U}
\end{equation}

\medskip
\noindent\textbf{Substitution into the Black-Scholes equation.}
Suppose \(V\) solves
\[
V_t+\frac12\sum_{i,j=1}^d Q_{ij}S_iS_jV_{S_iS_j}
+r\sum_{i=1}^d S_iV_{S_i}
-rV
-g(V)=0,
\]
or more generally \eqref{eq:nonlinearBS}. Substituting \eqref{eq:Vt_from_U} and \eqref{eq:spatial_from_U}, and multiplying by \(e^{r\tau}\), we obtain
\[
rU-U_\tau
+\frac12\sum_{i,j=1}^d Q_{ij}S_iS_jU_{S_iS_j}
+r\sum_{i=1}^d S_iU_{S_i}
-rU
-e^{r\tau}g(e^{-r\tau}U)=0.
\]
The \(rU\) terms cancel, yielding
\[
-U_\tau
+\frac12\sum_{i,j=1}^d Q_{ij}S_iS_jU_{S_iS_j}
+r\sum_{i=1}^d S_iU_{S_i}
-e^{r\tau}g(e^{-r\tau}U)=0.
\]
Therefore
\begin{equation}
\boxed{
U_\tau
=
\frac12\sum_{i,j=1}^d Q_{ij}S_iS_jU_{S_iS_j}
+r\sum_{i=1}^d S_iU_{S_i}
-f(\tau,U),
}
\label{eq:Ueq}
\end{equation}
where
\begin{equation}
\boxed{
f(\tau,y):=e^{r\tau}g(e^{-r\tau}y).
}
\label{eq:f_def_discount}
\end{equation}




\subsection{Log-price variables}
Next, we introduce logarithmic asset-price variables,variables which turn the Euler-type operators \(S_i\partial_{S_i}\) into ordinary derivatives \(\partial_{x_i}\). The scalar case is trated in in \cite[Ch.~5]{WilmottHowisonDewynne1995}, while the multi-dimensional case appears, for instance, in \cite[Ch.~8]{MusielaRutkowski2005}.


Let
\[
x_i=\ln S_i,\qquad S_i=e^{x_i},\qquad S=e^x,
\]
and define
\[
w(\tau,x):=U(\tau,e^x),\qquad x\in\R^d.
\]
We now compute explicitly how the spatial derivatives transform.

\medskip
\noindent\textbf{First derivatives.}
For each \(i=1,\dots,d\), since \(S_k=e^{x_k}\), one has
\[
\frac{\partial S_k}{\partial x_i}
=
\begin{cases}
S_i,& k=i,\\
0,& k\neq i.
\end{cases}
\]
Hence, by the chain rule,
\[
w_{x_i}(\tau,x)
=
\sum_{k=1}^d U_{S_k}(\tau,e^x)\,\frac{\partial S_k}{\partial x_i}
=
U_{S_i}(\tau,e^x)\,S_i.
\]
Therefore
\begin{equation}
\boxed{
w_{x_i}=S_i\,U_{S_i}.
}
\label{eq:first_log_derivative}
\end{equation}
Equivalently,
\[
S_i\partial_{S_i}=\partial_{x_i}.
\]

\medskip
\noindent\textbf{Second derivatives: off-diagonal case \(i\neq j\).}
Starting from \eqref{eq:first_log_derivative},
\[
w_{x_i}=S_iU_{S_i},
\]
differentiate with respect to \(x_j\), \(j\neq i\). Since \(S_i\) does not depend on \(x_j\),
\[
w_{x_ix_j}
=
\partial_{x_j}(S_iU_{S_i})
=
S_i\,\partial_{x_j}(U_{S_i}).
\]
Again by the chain rule,
\[
\partial_{x_j}(U_{S_i})
=
\sum_{k=1}^d U_{S_iS_k}\frac{\partial S_k}{\partial x_j}
=
U_{S_iS_j}S_j.
\]
Thus
\begin{equation}
\boxed{
w_{x_ix_j}=S_iS_j\,U_{S_iS_j},
\qquad i\neq j.
}
\label{eq:offdiag_log}
\end{equation}

\medskip
\noindent\textbf{Second derivatives: diagonal case \(i=j\).}
Differentiate \eqref{eq:first_log_derivative} with respect to \(x_i\):
\[
w_{x_ix_i}
=
\partial_{x_i}(S_iU_{S_i})
=
(\partial_{x_i}S_i)\,U_{S_i}
+
S_i\,\partial_{x_i}(U_{S_i}).
\]
Since \(\partial_{x_i}S_i=S_i\), and
\[
\partial_{x_i}(U_{S_i})
=
\sum_{k=1}^d U_{S_iS_k}\frac{\partial S_k}{\partial x_i}
=
U_{S_iS_i}S_i,
\]
we obtain
\[
w_{x_ix_i}
=
S_iU_{S_i}+S_i^2U_{S_iS_i}.
\]
Using again \eqref{eq:first_log_derivative}, this becomes
\begin{equation}
\boxed{
w_{x_ix_i}=w_{x_i}+S_i^2U_{S_iS_i}.
}
\label{eq:diag_log_pre}
\end{equation}
Hence
\begin{equation}
\boxed{
S_i^2U_{S_iS_i}=w_{x_ix_i}-w_{x_i}.
}
\label{eq:diag_log}
\end{equation}

\medskip
\noindent\textbf{Summary of the transformed operators.}
From \eqref{eq:offdiag_log} and \eqref{eq:diag_log}, we have
\[
S_iS_j\partial_{S_iS_j}
=
\begin{cases}
\partial_{x_ix_j},& i\neq j,\\[1mm]
\partial_{x_ix_i}-\partial_{x_i},& i=j.
\end{cases}
\]
Therefore
\begin{align}
\frac12\sum_{i,j=1}^d Q_{ij}S_iS_jU_{S_iS_j}
&=
\frac12\sum_{i\neq j}Q_{ij}w_{x_ix_j}
+\frac12\sum_{i=1}^d Q_{ii}(w_{x_ix_i}-w_{x_i})\nonumber\\
&=
\frac12\sum_{i,j=1}^d Q_{ij}w_{x_ix_j}
-\frac12\sum_{i=1}^d Q_{ii}w_{x_i}\nonumber\\
&=
\boxed{
\frac12\,\tr(QD_x^2w)-\frac12\sum_{i=1}^d Q_{ii}w_{x_i}.
}
\label{eq:2ndorderlog_detailed}
\end{align}
Here \(D_x^2w\) denotes the Hessian matrix of \(w\) with respect to \(x\).

\medskip
\noindent\textbf{The first-order Black-Scholes term.}
From \eqref{eq:first_log_derivative},
\[
r\sum_{i=1}^d S_iU_{S_i}
=
r\sum_{i=1}^d w_{x_i}
=
r\,\mathbf 1\cdot \nabla_x w,
\]
where \(\mathbf 1=(1,\dots,1)\in\R^d\).

\medskip
\noindent\textbf{Resulting equation in log-variables.}
Substituting \eqref{eq:2ndorderlog_detailed} into \eqref{eq:Ueq}, we obtain
\begin{align*}
w_\tau
&=
\frac12\,\tr(QD_x^2w)
-\frac12\sum_{i=1}^d Q_{ii}w_{x_i}
+r\sum_{i=1}^d w_{x_i}
-f(\tau,w)\\
&=
\frac12\,\tr(QD_x^2w)
+\sum_{i=1}^d \Bigl(r-\frac12Q_{ii}\Bigr)w_{x_i}
-f(\tau,w).
\end{align*}
Hence
\begin{equation}
\boxed{
w_\tau=\frac12\,\tr(QD_x^2w)+\beta\cdot\nabla_x w-f(\tau,w),
}
\label{eq:weq}
\end{equation}
where the constant drift vector \(\beta\in\R^d\) is given by
\[
\beta_i:=r-\frac12Q_{ii},
\qquad i=1,\dots,d.
\]

This shows that the logarithmic change of variables transforms the Euler
operators \(S_i\partial_{S_i}\) into the flat derivatives
\(\partial_{x_i}\), and converts the variable-coefficient Black-Scholes
diffusion into a constant-coefficient second-order operator in the
log-price variables.








\subsection{Remove transport by a moving frame}

Notice that after the logarithmic transformation a constant drift term remains.

\begin{equation}
w_\tau=\frac12\,\tr(QD_x^2w)+\beta\cdot\nabla_x w-f(\tau,w),
\qquad (\tau,x)\in\R_+\times\R^d,
\label{eq:weq_movingframe_start}
\end{equation}
where
\[
\beta=(\beta_1,\dots,\beta_d)\in\R^d,
\qquad
\beta_i=r-\frac12Q_{ii}.
\]

We now remove the first-order transport term by passing to a moving frame. Define
\[
u(\tau,y):=w(\tau,y-\beta\tau),
\qquad y\in\R^d.
\]
Equivalently, if we set
\[
x=y-\beta\tau,
\]
then
\[
u(\tau,y)=w(\tau,x).
\]

\medskip
\noindent\textbf{Step 1: time derivative.}
Since \(x=y-\beta\tau\), we have
\[
\frac{\partial x_i}{\partial\tau}=-\beta_i,
\qquad i=1,\dots,d.
\]
Applying the chain rule,
\[
u_\tau(\tau,y)
=
w_\tau(\tau,x)
+\sum_{i=1}^d w_{x_i}(\tau,x)\,\frac{\partial x_i}{\partial\tau}.
\]
Hence
\begin{equation}
\boxed{
u_\tau(\tau,y)=w_\tau(\tau,x)-\beta\cdot\nabla_x w(\tau,x).
}
\label{eq:u_tau_movingframe}
\end{equation}

\medskip
\noindent\textbf{Step 2: first spatial derivatives.}
Fix \(k\in\{1,\dots,d\}\). Since
\[
x_i=y_i-\beta_i\tau,
\]
we have
\[
\frac{\partial x_i}{\partial y_k}=\delta_{ik},
\]
where \(\delta_{ik}\) is the Kronecker symbol. Therefore
\[
u_{y_k}(\tau,y)
=
\sum_{i=1}^d w_{x_i}(\tau,x)\,\frac{\partial x_i}{\partial y_k}
=
w_{x_k}(\tau,x).
\]
Thus
\begin{equation}
\boxed{
\nabla_y u(\tau,y)=\nabla_x w(\tau,x).
}
\label{eq:grad_movingframe}
\end{equation}

\medskip
\noindent\textbf{Step 3: second spatial derivatives.}
Differentiating once more with respect to \(y_\ell\), we get
\[
u_{y_\ell y_k}(\tau,y)
=
\partial_{y_\ell}\bigl(w_{x_k}(\tau,x)\bigr)
=
\sum_{i=1}^d w_{x_ix_k}(\tau,x)\,\frac{\partial x_i}{\partial y_\ell}.
\]
Since \(\partial x_i/\partial y_\ell=\delta_{i\ell}\),
\[
u_{y_\ell y_k}(\tau,y)=w_{x_\ell x_k}(\tau,x).
\]
Hence
\begin{equation}
\boxed{
D_y^2u(\tau,y)=D_x^2w(\tau,x).
}
\label{eq:hessian_movingframe}
\end{equation}

\medskip
\noindent\textbf{Step 4: substitute into the equation.}
Using \eqref{eq:u_tau_movingframe}, \eqref{eq:grad_movingframe}, and \eqref{eq:hessian_movingframe}, equation \eqref{eq:weq_movingframe_start} gives
\begin{align*}
u_\tau(\tau,y)
&=
w_\tau(\tau,x)-\beta\cdot\nabla_x w(\tau,x)\\
&=
\left(\frac12\,\tr(QD_x^2w)+\beta\cdot\nabla_x w-f(\tau,w)\right)(\tau,x)
-\beta\cdot\nabla_x w(\tau,x)\\
&=
\frac12\,\tr(QD_x^2w)(\tau,x)-f(\tau,w(\tau,x)).
\end{align*}
Since \(D_x^2w(\tau,x)=D_y^2u(\tau,y)\) and \(w(\tau,x)=u(\tau,y)\), we conclude
\begin{equation}
\boxed{
u_\tau(\tau,y)=\frac12\,\tr(QD_y^2u(\tau,y))-f(\tau,u(\tau,y)).
}
\label{eq:ueq_movingframe_detailed}
\end{equation}

Thus the transport term \(\beta\cdot\nabla w\) has been completely removed.

\medskip
\noindent\textbf{Interpretation.}
The substitution
\[
u(\tau,y)=w(\tau,y-\beta\tau)
\]
corresponds to observing the solution in a frame moving with constant velocity \(\beta\). In this moving frame, the first-order drift disappears, and the equation reduces to a pure anisotropic diffusion with reaction term:
\[
u_\tau=\frac12\,\tr(QD_y^2u)-f(\tau,u).
\]
This is the natural form to which one applies the final linear change of variables that reduces the diffusion matrix to the identity.



\subsection{Reduction to the Laplacian}
Since the assets can be correlated, the diffusion matrix $Q$, which contains
variances and covariances, generally has nonzero off-diagonal entries. This
implies that the associated second-order operator involves mixed derivatives
and that the diffusion is anisotropic. As a result, the evolution stretches
and rotates the space.

To remove these correlations and recover isotropic diffusion, we apply a
Cholesky factorization of $Q$. This allows us to work in transformed
coordinates in which the diffusion matrix becomes the identity and the
operator reduces to the Laplacian.

Proposition~\ref{prop:cholesky_spd}
provides an invertible matrix $L$ such that
\[
LL^\top=\frac12\,Q
\quad\text{(e.g.\ Cholesky factorization).}
\]
Here $y$ denotes the intermediate log-price variable and $z$ the new
whitened variable. Let $y=Lz$ and define
$\tilde u(\tau,z):=u(\tau,Lz)$.
Then a standard linear change of variables gives
\[
\frac12\,\tr(QD^2_y u)=\Delta_z \tilde u.
\]
We verify this identity explicitly. Let \(y=Lz\) and define
\[
\tilde u(\tau,z):=u(\tau,Lz),\qquad z\in\R^d.
\]
We compute the derivatives of \(\tilde u\) with respect to \(z\).

For each \(k=1,\dots,d\), the chain rule gives
\[
\partial_{z_k}\tilde u(\tau,z)
=
\sum_{i=1}^d \partial_{y_i}u(\tau,Lz)\,\partial_{z_k}(Lz)_i.
\]
Since
\[
(Lz)_i=\sum_{m=1}^d L_{im}z_m,
\]
we have \(\partial_{z_k}(Lz)_i=L_{ik}\), hence
\[
\partial_{z_k}\tilde u(\tau,z)
=
\sum_{i=1}^d L_{ik}\,\partial_{y_i}u(\tau,Lz).
\]
In vector form,
\[
\nabla_z\tilde u(\tau,z)=L^\top \nabla_y u(\tau,Lz).
\]
Differentiating once more with respect to \(z_\ell\), we find
\[
\partial_{z_\ell z_k}\tilde u(\tau,z)
=
\sum_{i=1}^d L_{ik}\,\partial_{z_\ell}\big(\partial_{y_i}u(\tau,Lz)\big).
\]
Applying the chain rule again,
\[
\partial_{z_\ell}\big(\partial_{y_i}u(\tau,Lz)\big)
=
\sum_{j=1}^d \partial_{y_jy_i}u(\tau,Lz)\,\partial_{z_\ell}(Lz)_j
=
\sum_{j=1}^d L_{j\ell}\,\partial_{y_jy_i}u(\tau,Lz).
\]
Therefore
\[
\partial_{z_\ell z_k}\tilde u(\tau,z)
=
\sum_{i,j=1}^d L_{ik}L_{j\ell}\,\partial_{y_iy_j}u(\tau,Lz).
\]
Thus the Hessian transforms according to
\[
D_z^2\tilde u(\tau,z)
=
L^\top \big(D_y^2u(\tau,Lz)\big)L.
\]

Taking the trace, we obtain
\[
\Delta_z\tilde u(\tau,z)
=
\tr\!\big(D_z^2\tilde u(\tau,z)\big)
=
\tr\!\Big(L^\top \big(D_y^2u(\tau,Lz)\big)L\Big).
\]
Using the cyclicity of the trace,
\[
\Delta_z\tilde u(\tau,z)
=
\tr\!\Big((LL^\top)\,D_y^2u(\tau,Lz)\Big).
\]
If \(L\) is chosen so that
\[
LL^\top=\frac12\,Q,
\]
then
\[
\Delta_z\tilde u(\tau,z)
=
\tr\!\Big(\frac12\,Q\,D_y^2u(\tau,Lz)\Big)
=
\frac12\,\tr\!\big(QD_y^2u(\tau,Lz)\big).
\]
Hence
\[
\boxed{
\frac12\,\tr(QD_y^2u)(\tau,Lz)=\Delta_z\tilde u(\tau,z).
}
\]
Substituting this into
\[
u_\tau=\frac12\,\tr(QD_y^2u)-f(\tau,u),
\]
we arrive at
\[
\partial_\tau \tilde u-\Delta_z\tilde u+f(\tau,\tilde u)=0.
\]

Therefore \eqref{eq:ueq_movingframe_detailed} becomes
\begin{equation}
\begin{aligned}
\partial_\tau \tilde u - \Delta \tilde u + f(\tau,\tilde u) &= 0,
\qquad (\tau,z)\in\R_+\times\R^d,\\
f(\tau,y) &= e^{r\tau}\,g(e^{-r\tau}y).
\end{aligned}
\label{eq:semilinearheat_general}
\end{equation}
In the positively homogeneous degree-$1$ case (notably $g(v)=a v^+ - b v^-$), one has $f(\tau,\cdot)\equiv g(\cdot)$,
so \eqref{eq:semilinearheat_general} reduces to the \emph{time-independent} semilinear heat equation
\begin{equation}
\boxed{
\partial_\tau \tilde u - \Delta \tilde u + f(\tilde u)=0\quad\text{on }\R_+\times\R^d,
}
\label{eq:semilinearheat_reduction}
\end{equation}
with $f=g$.

The Cholesky factorization $LL^\top = \tfrac{1}{2}Q$
diagonalises the diffusion to the standard Laplacian
$\Delta_z$, so the subsequent semilinear theory may be stated in
whitened variables without further reference to the covariance structure
of the original model.


\subsection{Summary of the full transformation}
The preceding subsections can be summarized as a single dictionary between pricing variables and heat variables. Starting from $(t,S)$ and $V(t,S)$, define:
\begin{align*}
\tau &= T-t,\\
U(\tau,S) &= e^{r\tau}V(T-\tau,S),\\
x &= \ln S, \qquad w(\tau,x)=U(\tau,e^x),\\
u(\tau,y) &= w(\tau,y-\beta\tau),\qquad \beta_i=r-\tfrac12Q_{ii},\\
\tilde u(\tau,z) &= u(\tau,Lz), \qquad y=Lz, \qquad LL^\top=\tfrac12 Q.
\end{align*}
Then $\tilde u$ solves the semilinear heat Cauchy problem
\eqref{eq:semilinearheat} (introduced and studied in
Section~\ref{sec:shared_theory}).

We have thus reduced the original pricing problem \eqref{eq:nonlinearBS} to the Cauchy problem.

\part*{Part II - Analysis of the Semilinear Problem}
\addcontentsline{toc}{part}{Part II -- Analysis of the Semilinear Problem}

\section{Semilinear Theory}
\label{sec:shared_theory}

The transformation in Section~\ref{sec:transform} reduces the pricing problem to a semilinear heat equation. Before using any sign structure, we record the results that depend only on the Lipschitz and piecewise-linear framework. 

We work with the semilinear heat equation on $\R^d$
\begin{equation}
\boxed{
\partial_\tau \tilde u - \Delta \tilde u + f(\tilde u)=0,
\qquad (\tau,z)\in(0,\infty)\times\R^d,
}
\label{eq:semilinearheat}
\end{equation}
supplemented with the Cauchy datum $\tilde u(0,z)=\tilde u_0(z)$.

\subsection{Assumptions on the nonlinearities}
\label{subsec:f_assumptions}

We consider, at this point, the piecewise-linear models with the truncation structure
\begin{equation}
f_-(u)=a u^+-b u^-,\qquad
f_+(u)=a u^+ + b u^-,
\qquad a,b\ge 0.
\label{eq:f_piecewise_shared}
\end{equation}

We underline again that they are globally Lipschitz.



\subsection{Heat semigroup bounds and parabolic smoothing}
\label{subsec:semigroup_smoothing}

Let $S(\tau):=e^{\tau\Delta}$, defined via Fourier multiplier $e^{-\tau|\xi|^2}$, denote the heat semigroup on $\R^d$.
The following standard estimates are the analytic engine behind the shared theory: diffusion improves integrability and differentiability immediately for positive time. They will be used repeatedly in the mild-solution and smoothing arguments.

\begin{lemma}[$L^p$-$L^q$ smoothing for the heat semigroup]
\label{lem:heat_LpLq}
For $1\le p\le q\le\infty$ and $\tau>0$,
\begin{equation}
\|S(\tau)\varphi\|_{L^q(\R^d)}
\le C_{d,p,q}\,\tau^{-\frac d2(\frac1p-\frac1q)}\,\|\varphi\|_{L^p(\R^d)}.
\label{eq:heat_LpLq}
\end{equation}
Moreover, for $\tau>0$,
\begin{equation}
\|\nabla S(\tau)\varphi\|_{L^q(\R^d)}
\le C_{d,p,q}\,\tau^{-\frac12-\frac d2(\frac1p-\frac1q)}\,\|\varphi\|_{L^p(\R^d)}.
\label{eq:heat_grad_LpLq}
\end{equation}
In particular, the sharp endpoint $p=1$, $q=\infty$ reads
\begin{equation}
\boxed{
\|S(\tau)\varphi\|_{L^\infty(\R^d)}
\le (4\pi\tau)^{-d/2}\,\|\varphi\|_{L^1(\R^d)},
\qquad \tau>0.
}
\label{eq:heat_L1_Linf}
\end{equation}
\end{lemma}

\begin{proof}
Consider
$$
S(\tau)\varphi=\int_{\R^d} G_\tau(x-z)\varphi(z)\,dz,
$$
with the Gaussian kernel
$G_\tau(z)=(4\pi\tau)^{-d/2}e^{-|z|^2/(4\tau)}$, one has
$\|G_\tau\|_{L^r}=C_{d,r}\,\tau^{-\frac d2(1-1/r)}$ for $1\le r\le\infty$.
Indeed, for $1\le r<\infty$ a change of variables $z=\sqrt{\tau}\,y$ gives
\[
\|G_\tau\|_{L^r}^r
=(4\pi\tau)^{-dr/2}\int_{\R^d} e^{-r|z|^2/(4\tau)}\,dz
=C_{d,r}\,\tau^{-\frac{dr}{2}+\frac d2},
\]
and taking the $r$th root yields the claimed exponent. The case $r=\infty$
is immediate from $\|G_\tau\|_{\infty}=(4\pi\tau)^{-d/2}$.

Now fix $1\le p\le q\le\infty$ and define $r\in[1,\infty]$ by
\[
\frac1r=1+\frac1q-\frac1p.
\]
Since $p\le q$, one has $0\le 1/r\le 1$, so this choice is admissible, and
equivalently
\[
1+\frac1q=\frac1p+\frac1r,
\qquad
1-\frac1r=\frac1p-\frac1q.
\]
Therefore Young's convolution inequality gives
\[
\|S(\tau)\varphi\|_{L^q}
=\|G_\tau*\varphi\|_{L^q}
\le \|G_\tau\|_{L^r}\,\|\varphi\|_{L^p}
\le C_{d,p,q}\,\tau^{-\frac d2(\frac1p-\frac1q)}\,\|\varphi\|_{L^p},
\]
which proves \eqref{eq:heat_LpLq}.

For the gradient estimate, note that
\[
\nabla G_\tau(z)=-\frac{z}{2\tau}G_\tau(z).
\]
Hence the same scaling argument gives
\[
\|\nabla G_\tau\|_{L^r}
\le C_{d,r}\,\tau^{-1/2-\frac d2(1-1/r)}.
\]
Applying Young's inequality once more,
\[
\|\nabla S(\tau)\varphi\|_{L^q}
=\|(\nabla G_\tau)*\varphi\|_{L^q}
\le \|\nabla G_\tau\|_{L^r}\,\|\varphi\|_{L^p}
\le C_{d,p,q}\,\tau^{-\frac12-\frac d2(\frac1p-\frac1q)}\,\|\varphi\|_{L^p},
\]
which is \eqref{eq:heat_grad_LpLq}.

Finally, the sharp endpoint $p=1$, $q=\infty$ corresponds to $r=\infty$, so
\[
\|S(\tau)\varphi\|_{L^\infty}
\le \|G_\tau\|_{L^\infty}\,\|\varphi\|_{L^1}
=(4\pi\tau)^{-d/2}\,\|\varphi\|_{L^1},
\]
which is exactly \eqref{eq:heat_L1_Linf}. Since $G_\tau\ge 0$ and
$\int_{\R^d} G_\tau\,dz=1$, this representation also shows that $S(\tau)$
preserves nonnegativity.
\end{proof}

\subsection{Instantaneous \texorpdfstring{$H^1$}{H1} regularization and energy class data}
\label{subsec:H1_instantaneous_regularization}

We now separate two different facts:
\begin{itemize}[leftmargin=2em]
\item[(i)] if $\tilde u_0\in L^2(\R^d)$, then the parabolic semigroup regularizes instantly and
$\tilde u(\tau)\in H^1(\R^d)$ for every $\tau>0$;
\item[(ii)] if one wants an $H^1$ energy identity starting exactly from $\tau=0$, then one must assume
$\tilde u_0\in H^1(\R^d)$.
\end{itemize}
The point is that a mere mild $L^2$ solution only satisfies $\tilde u\in C([0,T];L^2)$, so the formal pairings
$\big(\partial_\tau \tilde u,\tilde u\big)_{L^2}$ and $\big(-\Delta \tilde u,\tilde u\big)_{L^2}$ are not a priori meaningful at
$\tau=0$. On the other hand, the heat semigroup immediately improves regularity for every positive time.

\paragraph{Step 1: instantaneous $H^1$ regularization from $L^2$ data.}
Assume first only $\tilde u_0\in L^2(\R^d)$ and let $\tilde u$ be the mild solution of
\eqref{eq:semilinearheat}, i.e.
\begin{equation}
\tilde u(\tau)=S(\tau)\tilde u_0-\int_0^\tau S(\tau-s)f(\tilde u(s))\,ds,
\qquad S(\tau)=e^{\tau\Delta}.
\label{eq:duhamel_H1}
\end{equation}
We claim that for every $\tau>0$,
\begin{equation}
\|\nabla \tilde u(\tau)\|_{L^2}
\le C\,\tau^{-1/2}\|\tilde u_0\|_{L^2}
+ C\int_0^\tau (\tau-s)^{-1/2}\,\|f(\tilde u(s))\|_{L^2}\,ds.
\label{eq:H1_smoothing_mild}
\end{equation}
This is the precise form of the ``$L^2\to H^1$ smoothing'' used throughout the paper.

To prove \eqref{eq:H1_smoothing_mild}, differentiate \eqref{eq:duhamel_H1} in space:
\[
\nabla \tilde u(\tau)=\nabla S(\tau)\tilde u_0-\int_0^\tau \nabla S(\tau-s)f(\tilde u(s))\,ds.
\]
Hence, by the triangle inequality in $L^2$,
\[
\|\nabla \tilde u(\tau)\|_{L^2}
\le \|\nabla S(\tau)\tilde u_0\|_{L^2}
+ \int_0^\tau \|\nabla S(\tau-s)f(\tilde u(s))\|_{L^2}\,ds.
\]
It remains to estimate the gradient of the heat semigroup on $L^2$. We use \eqref{eq:heat_grad_LpLq}, giving a direct proof in the particular case $p=q=2$. Using Fourier variables,
\[
\widehat{S(\tau)\phi}(\xi)=e^{-\tau|\xi|^2}\,\widehat\phi(\xi),
\]
so
\[
\|\nabla S(\tau)\phi\|_{L^2}^2
= \int_{\R^d}|\xi|^2 e^{-2\tau|\xi|^2}|\widehat\phi(\xi)|^2\,d\xi.
\]
Since the scalar function $y\mapsto y e^{-2y}$ is bounded on $[0,\infty)$, there exists $C>0$ such that
$|\xi|^2 e^{-2\tau|\xi|^2}\le C\tau^{-1}$ for all $\xi$ and all $\tau>0$. Therefore
\[
\|\nabla S(\tau)\phi\|_{L^2}^2\le C\tau^{-1}\|\phi\|_{L^2}^2,
\qquad\text{i.e.}\qquad
\|\nabla S(\tau)\phi\|_{L^2}\le C\tau^{-1/2}\|\phi\|_{L^2}.
\]
Applying this estimate with $\phi=\tilde u_0$ and then with $\phi=f(\tilde u(s))$ gives \eqref{eq:H1_smoothing_mild}.
In particular, for every fixed $\varepsilon>0$,
\begin{equation}
\sup_{\tau\in[\varepsilon,T]}\|\nabla \tilde u(\tau)\|_{L^2}<\infty,
\label{eq:H1_eps_bound}
\end{equation}
provided the right-hand side of \eqref{eq:H1_smoothing_mild} is finite.

When $f$ is globally Lipschitz and $f(0)=0$, one has
\[
|f(r)|\le L|r|\qquad(r\in\R),
\]
for some Lipschitz constant $L$. Moreover, if one assumes that $\|\tilde u(s)\|_{L^2}\le \varphi(s)\|\tilde u_0\|_{L^2},$ 
\begin{equation}
\|f(\tilde u(s))\|_{L^2}\le L\|\tilde u(s)\|_{L^2}\le \varphi(s)L\|\tilde u_0\|_{L^2}
\label{eq:L2_forcing_bound}
\end{equation}
 Inserting \eqref{eq:L2_forcing_bound} into \eqref{eq:H1_smoothing_mild} yields
\begin{align}
\|\nabla \tilde u(\tau)\|_{L^2}
&\le C\tau^{-1/2}\|\tilde u_0\|_{L^2}
 + CL\|\tilde u_0\|_{L^2}\int_0^\tau (\tau-s)^{-1/2}\varphi(s)\,ds, \quad 0<\tau\le T.
\label{eq:H1_smoothing_explicit}
\end{align}
if $(\tau-s)^{-1/2}\varphi(s)\in L^1((0,\infty))$. Hence the solution belongs to $H^1(\R^d)$ for every positive time, even when the initial datum is only in $L^2$.
What one cannot conclude from \eqref{eq:H1_smoothing_explicit} is continuity into $H^1$ at $\tau=0$: indeed, the term
$\tau^{-1/2}\|\tilde u_0\|_{L^2}$ blows up as $\tau\downarrow0$. This is why an $H^1$ estimate starting at the initial time
requires stronger data.




\paragraph{Motivation for \texorpdfstring{$H^1$}{H1} initial data.}
We now give an argument explaining why the assumption
\(\tilde{u}_0 \in H^1(\mathbb{R}^d)\) is needed to propagate the
\(H^1\) estimate all the way to \(\tau=0\), rather than only for \(\tau>0\).
The rigorous statement and proof are given in
Theorem~\ref{thm:H1_piecewise_wp} below.
One assumes in addition
\begin{equation}
\tilde u_0\in H^1(\R^d).
\label{eq:H1_initial_data}
\end{equation}
Indeed, if \(S(\tau)=e^{\tau\Delta}\) denotes the heat semigroup, then
\[
\widehat{S(\tau)\tilde u_0}(\xi)=e^{-\tau|\xi|^2}\widehat{\tilde u_0}(\xi),
\]
and therefore
\[
\|S(\tau)\tilde u_0-\tilde u_0\|_{H^1(\R^d)}^2
=
\int_{\R^d}(1+|\xi|^2)\,
|e^{-\tau|\xi|^2}-1|^2\,|\widehat{\tilde u_0}(\xi)|^2\,d\xi.
\]
Since \(e^{-\tau|\xi|^2}\to 1\) pointwise as \(\tau\downarrow0\), and
\[
|e^{-\tau|\xi|^2}-1|^2\le 4,
\]
the integrand is dominated by
\[
4(1+|\xi|^2)|\widehat{\tilde u_0}(\xi)|^2,
\]
which is integrable because \(\tilde u_0\in H^1(\R^d)\). Hence, by a convergence argument,
\begin{equation}
S(\tau)\tilde u_0\to \tilde u_0
\qquad\text{strongly in }H^1(\R^d)
\quad\text{as }\tau\downarrow 0.
\label{eq:H1_strong_continuity}
\end{equation}

Now write the mild solution in Duhamel form:
\[
\tilde u(\tau)
=
S(\tau)\tilde u_0
-
\int_0^\tau S(\tau-s)f(\tilde u(s))\,ds.
\]
Since the heat semigroup is bounded on \(H^1(\R^d)\), we have
\[
\left\|
\int_0^\tau S(\tau-s)f(\tilde u(s))\,ds
\right\|_{H^1}
\le
\int_0^\tau \|f(\tilde u(s))\|_{H^1}\,ds.
\]
If \(f\) is Lipschitz on \(H^1\), then
\[
\|f(\tilde u(s))\|_{H^1}\le C\,\|\tilde u(s)\|_{H^1},
\]
and if \(\tilde u\in C([0,T];H^1(\R^d))\), the right-hand side tends to \(0\) as \(\tau\downarrow0\). Therefore
\[
\tilde u(\tau)\to \tilde u_0
\qquad\text{in }H^1(\R^d)
\quad\text{as }\tau\downarrow0.
\]
The fixed-point argument of Theorem~\ref{thm:H1_piecewise_wp}
below makes this rigorous.








\begin{remark}[Interpretation for rough data]
If only $\tilde u_0\in L^2(\R^d)$ is assumed, then the $H^1$ energy identity from the $H^1$ theory need not make sense at the initial time,
but \eqref{eq:H1_smoothing_mild} still shows that $\tilde u(\tau)\in H^1(\R^d)$ for every $\tau>0$. Equivalently,
for every $\varepsilon>0$ one may perform the $H^1$ energy method on $[\varepsilon,T]$ and then let $\varepsilon\downarrow0$
only at the level of inequalities. After transport back to Black-Scholes variables, this means that an $L^2_\omega$ payoff gives
instant weighted $H^1_\omega$ regularization of the discounted solution $U$ for every positive backward time.
\end{remark}



\begin{remark}[Endpoint smoothing for mild solutions]
\label{rem:duhamel_Linf}
Let $\tilde u$ be a mild solution of \eqref{eq:semilinearheat}, i.e.
\[
\tilde u(\tau)=S(\tau)\tilde u_0-\int_0^\tau S(\tau-s)\,f(\tilde u(s))\,ds.
\]
Applying \eqref{eq:heat_L1_Linf} yields, for every $\tau>0$,
\begin{equation}
\|\tilde u(\tau)\|_{L^\infty}
\le (4\pi\tau)^{-d/2}\,\|\tilde u_0\|_{L^1}
+\int_0^\tau (4\pi(\tau-s))^{-d/2}\,\|f(\tilde u(s))\|_{L^1}\,ds,
\label{eq:duhamel_Linf_bound}
\end{equation}
which upgrades $L^1$ information into pointwise control for $\tau>0$.
Combining \eqref{eq:heat_LpLq}-\eqref{eq:heat_grad_LpLq} with the Duhamel formula similarly yields
instantaneous smoothing in Sobolev spaces for $\tau>0$.
\end{remark}

\subsection{Well-posedness in \texorpdfstring{$L^2$}{L2} for globally Lipschitz \texorpdfstring{$f$}{f}}
\label{subsec:mild_wp}

Assume $f$ is globally Lipschitz. Let $S(\tau)=e^{\tau\Delta}$ be the heat semigroup on $L^2(\R^d)$.
A \emph{mild solution} of \eqref{eq:semilinearheat} is a function
$\tilde u\in C([0,\infty);L^2)$ satisfying the Duhamel formula
\begin{equation}
\tilde u(\tau)=S(\tau)\tilde u_0 - \int_0^\tau S(\tau-s)\,f(\tilde u(s))\,ds.
\label{eq:duhamel}
\end{equation}

\begin{theorem}[Global well-posedness in $L^2$ (globally Lipschitz case)]
\label{thm:L2_global_wp}
Assume $f$ is globally Lipschitz. For each $\tilde u_0\in L^2(\R^d)$ there exists a unique global mild solution $\tilde u\in C([0,\infty);L^2(\R^d))$ of \eqref{eq:semilinearheat}. Moreover, on every bounded time interval the solution depends Lipschitz continuously on the initial datum.
\end{theorem}

\begin{proof}
Let $L_f$ be a global Lipschitz constant for $f$, so that
\[
|f(\xi)-f(\eta)|\le L_f |\xi-\eta|
\qquad\text{for all }\xi,\eta\in\R.
\]
Since $f$ is globally Lipschitz, it has at most linear growth:
\[
|f(\xi)|\le |f(0)|+L_f|\xi|,
\qquad \xi\in\R.
\]
Hence for every $u\in L^2(\R^d)$ we, since we have $f(0)=0$, so
\begin{equation}
\|f(u)\|_{L^2}\le L_f\|u\|_{L^2}.
\label{eq:f_L2_bound}
\end{equation}
We now fix $T>0$ and work on the Banach space
\[
X_T:=C([0,T];L^2(\R^d)),
\qquad
\|u\|_{X_T}:=\sup_{0\le \tau\le T}\|u(\tau)\|_{L^2}.
\]

Define the mapping $\mathcal T:X_T\to X_T$ by
\begin{equation}
(\mathcal Tu)(\tau)
:=
S(\tau)\tilde u_0-\int_0^\tau S(\tau-s)\,f(u(s))\,ds,
\qquad 0\le \tau\le T.
\label{eq:fixed_point_map}
\end{equation}
We show in several steps that $\mathcal T$ has a unique fixed point.

\medskip
\noindent\textbf{Step 1: \(\mathcal T\) is well defined on \(X_T\).}
Let $u\in X_T$. Since $u\in C([0,T];L^2)$ and $f$ is globally Lipschitz, the map
\[
s\longmapsto f(u(s))
\]
belongs to $C([0,T];L^2)$. Indeed,
\[
\|f(u(s))-f(u(s'))\|_{L^2}\le L_f\|u(s)-u(s')\|_{L^2} \to 0
\qquad\text{as }s'\to s.
\]
The heat semigroup satisfies
\[
\|S(t)\|_{L^2}\le \|u_0\|_{L^2},
\qquad t\ge 0.
\]
Therefore the map
\[
\tau\longmapsto \int_0^\tau S(\tau-s)\,f(u(s))\,ds
\]
is continuous as an $L^2$-valued function on $[0,T]$. Since $\tau\mapsto S(\tau)\tilde u_0$ is also continuous in $L^2$, it follows that $\mathcal Tu\in X_T$.

\medskip
\noindent\textbf{Step 2: contraction estimate.}
Let $u,v\in X_T$. Using the definition \eqref{eq:fixed_point_map}, the semigroup bound, and the Lipschitz property of $f$, we obtain for each $\tau\in[0,T]$:
\begin{align*}
\|(\mathcal Tu)(\tau)-(\mathcal Tv)(\tau)\|_{L^2}
&=
\left\|
\int_0^\tau S(\tau-s)\bigl(f(u(s))-f(v(s))\bigr)\,ds
\right\|_{L^2} \\
&\le
\int_0^\tau
\|S(\tau-s)\bigl(f(u(s))-f(v(s))\bigr)\|_{L^2}\,ds \\
&\le
\int_0^\tau \|f(u(s))-f(v(s))\|_{L^2}\,ds \\
&\le
L_f\int_0^\tau \|u(s)-v(s)\|_{L^2}\,ds \\
&\le
L_f T\,\|u-v\|_{X_T}.
\end{align*}
Taking the supremum over $\tau\in[0,T]$ gives
\begin{equation}
\|\mathcal Tu-\mathcal Tv\|_{X_T}\le L_f T\,\|u-v\|_{X_T}.
\label{eq:XT_contraction_estimate}
\end{equation}

\medskip
\noindent\textbf{Step 3: local existence and uniqueness.}
If $T>0$ is chosen so that
\[
L_f T<1,
\]
then \eqref{eq:XT_contraction_estimate} shows that $\mathcal T$ is a contraction on the complete metric space $X_T$. Banach's fixed-point theorem therefore yields a unique $u\in X_T$ such that
\[
u=\mathcal Tu.
\]
By construction, this fixed point satisfies \eqref{eq:duhamel} on $[0,T]$, hence is a unique mild solution on $[0,T]$.

\medskip
\noindent\textbf{Step 4: extension to a global solution.}
The local existence time depends only on the Lipschitz constant $L_f$, not on the size of the initial datum. Starting from time $0$, we first solve on $[0,T_*]$ for some $T_*>0$ such that $L_f T_*<1$. The solution value $\tilde u(T_*)\in L^2$ may then be used as new initial data, and the same fixed-point argument gives a unique solution on $[T_*,2T_*]$. Iterating this procedure produces a unique mild solution on every interval $[0,nT_*]$, hence on all of $[0,\infty)$.

\medskip
\noindent\textbf{Step 5: uniqueness on arbitrary bounded intervals.}
Let $\tilde u,\tilde v\in C([0,T];L^2)$ be two mild solutions with the same initial datum. Then
\[
\tilde u(\tau)-\tilde v(\tau)
=
-\int_0^\tau S(\tau-s)\bigl(f(\tilde u(s))-f(\tilde v(s))\bigr)\,ds.
\]
Arguing as above,
\[
\|\tilde u(\tau)-\tilde v(\tau)\|_{L^2}
\le
L_f\int_0^\tau \|\tilde u(s)-\tilde v(s)\|_{L^2}\,ds.
\]
By Gronwall's inequality,
\[
\|\tilde u(\tau)-\tilde v(\tau)\|_{L^2}=0
\qquad\text{for all }\tau\in[0,T].
\]
Thus the mild solution is unique on every bounded interval, and hence globally unique.

\medskip
\noindent\textbf{Step 6: Lipschitz dependence on the initial datum.}
Let $\tilde u,\tilde v$ be the mild solutions corresponding to initial data $\tilde u_0,\tilde v_0\in L^2$. Subtracting the two Duhamel formulas gives
\[
\tilde u(\tau)-\tilde v(\tau)
=
S(\tau)(\tilde u_0-\tilde v_0)
-\int_0^\tau S(\tau-s)\bigl(f(\tilde u(s))-f(\tilde v(s))\bigr)\,ds.
\]
Hence
\[
\|\tilde u(\tau)-\tilde v(\tau)\|_{L^2}
\le
\|\tilde u_0-\tilde v_0\|_{L^2}
+
L_f\int_0^\tau \|\tilde u(s)-\tilde v(s)\|_{L^2}\,ds.
\]
Applying Gronwall's inequality once more, we obtain
\[
\|\tilde u(\tau)-\tilde v(\tau)\|_{L^2}
\le
e^{L_f\tau}\|\tilde u_0-\tilde v_0\|_{L^2},
\qquad 0\le \tau\le T.
\]
Taking the supremum over $\tau\in[0,T]$ yields
\[
\|\tilde u-\tilde v\|_{X_T}
\le
e^{L_f T}\|\tilde u_0-\tilde v_0\|_{L^2}.
\]
This proves Lipschitz continuous dependence on the initial datum on every bounded time interval.
\end{proof}


\subsection{Local and global well-posedness in \texorpdfstring{$H^1$}{H1} for the piecewise-linear model}
\label{subsec:H1_piecewise_wp}

We now prove the $H^1$ well-posedness result for the piecewise-linear models
\[
f_-(u)=a\,u^+-b\,u^-,\qquad f_+(u)=a\,u^+ + b\,u^-,
\qquad a,b\ge 0.
\]
Unlike the smooth $C^1$ framework considered earlier, this nonlinearity is only
piecewise linear; however, its global Lipschitz continuity is sufficient for a
direct fixed-point argument in $H^1(\R^d)$.


\begin{lemma}[Positive and negative parts in $H^1$]
\label{lem:pm_parts_H1}
Let $u\in H^1(\R^d)$. Then $u^+,u^-\in H^1(\R^d)$, and
\[
\nabla u^+ = \mathbf 1_{\{u>0\}}\,\nabla u,
\qquad
\nabla u^- = -\mathbf 1_{\{u<0\}}\,\nabla u
\quad \text{  on }\R^d.
\]
In particular,
\[
\|u^+\|_{H^1}\le \|u\|_{H^1},
\qquad
\|u^-\|_{H^1}\le \|u\|_{H^1}.
\]
Consequently, for either piecewise-linear choice $f=f_-$ or $f=f_+$ with $a,b\ge 0$
one has $f(u)\in H^1(\R^d)$ and
\begin{equation}
\|f(u)\|_{H^1}\le \sqrt{2}\max(a,b)\,\|u\|_{H^1}.
\label{eq:f_piecewise_H1_bound}
\end{equation}
Moreover, for all $u,v\in H^1(\R^d)$,
\begin{equation}
\|f(u)-f(v)\|_{H^1}\le \sqrt{2}\max(a,b)\,\|u-v\|_{H^1}.
\label{eq:f_piecewise_H1_Lip}
\end{equation}
\end{lemma}

\begin{proof}
Since
\[
u^+=\max(u,0),\qquad u^-=\max(-u,0),
\]
the truncation map $s\mapsto s^+$ is 1-Lipschitz on $\R$, and likewise
$s\mapsto s^-$. By Proposition~\ref{prop:sobolev_truncation}, this implies
$u^+,u^-\in H^1(\R^d)$ and
\[
\nabla u^+ = \mathbf 1_{\{u>0\}}\,\nabla u,
\qquad
\nabla u^- = -\mathbf 1_{\{u<0\}}\,\nabla u
\quad\text{ }
\]
Hence
\[
\|u^+\|_{L^2}\le \|u\|_{L^2},
\qquad
\|\nabla u^+\|_{L^2}\le \|\nabla u\|_{L^2},
\]
and similarly for \(u^-\), giving
\[
\|u^+\|_{H^1}\le \|u\|_{H^1},
\qquad
\|u^-\|_{H^1}\le \|u\|_{H^1}.
\]

Now let $f$ denote either $f_-$ or $f_+$.
Then
\[
\|f(u)\|_{H^1}
\le a\|u^+\|_{H^1}+b\|u^-\|_{H^1}
\le \max(a,b)\bigl(\|u^+\|_{H^1}+\|u^-\|_{H^1}\bigr).
\]
Since \(\{u>0\}\) and \(\{u<0\}\) are disjoint,
\[
\|\nabla u^+\|_{L^2}^2+\|\nabla u^-\|_{L^2}^2=\|\nabla u\|_{L^2}^2,
\qquad
\|u^+\|_{L^2}^2+\|u^-\|_{L^2}^2=\|u\|_{L^2}^2.
\]
Thus
\[
\|u^+\|_{H^1}^2+\|u^-\|_{H^1}^2=\|u\|_{H^1}^2,
\]
and Cauchy's inequality gives
\[
\|u^+\|_{H^1}+\|u^-\|_{H^1}\le \sqrt{2}\,\|u\|_{H^1}.
\]
This proves \eqref{eq:f_piecewise_H1_bound}.
Likewise,
\[
f(u)-f(v)=a\,(u^+-v^+)-b\,(u^-v^-),
\]
and using again that the maps \(s\mapsto s^\pm\) are 1-Lipschitz on \(H^1\), with the same disjoint-support estimate applied to \(u-v\),
we obtain \eqref{eq:f_piecewise_H1_Lip}.
Since the bounds \(\|u^\pm\|_{H^1}\le \|u\|_{H^1}\) and the identities \(\nabla u^\pm = \pm \mathbf{1}_{\{\pm u > 0\}}\nabla u\) do not depend on the sign in front of \(u^-\) in the definition of \(f\), the estimates \eqref{eq:f_piecewise_H1_bound} and \eqref{eq:f_piecewise_H1_Lip} hold identically for both the dissipative nonlinearity \(f_-(u)=au^+-bu^-\) and the non-dissipative nonlinearity \(f_+(u)=au^+ + bu^-\), with the same constant \(\sqrt{2}\max(a,b)\).
\end{proof}

\begin{theorem}[Local and global well-posedness in $H^1$ for the piecewise-linear models]
\label{thm:H1_piecewise_wp}
Let
\[
f=f_-\text{ or }f=f_+,
\qquad a,b\ge 0,
\]
and let $\tilde u_0\in H^1(\R^d)$. Then there exists $T>0$ and a unique mild solution
\[
\tilde u\in C([0,T];H^1(\R^d))
\]
of
\[
\partial_\tau \tilde u-\Delta \tilde u+f(\tilde u)=0
\qquad \text{in } (0,\infty)\times\R^d.
\]
Moreover, the solution depends continuously on the initial data in $H^1(\R^d)$.

Since $f$ is globally Lipschitz on $\R$, the local solution extends uniquely to all times, and therefore
\[
\tilde u\in C([0,\infty);H^1(\R^d)).
\]
\end{theorem}

\begin{proof}
We prove the result by a Banach fixed-point argument in the Banach space
\[
X_T:=C([0,T];H^1(\R^d)),
\qquad
\|u\|_{X_T}:=\sup_{0\le \tau\le T}\|u(\tau)\|_{H^1}.
\]

The mild formulation of the equation is
\begin{equation}
u(\tau)=S(\tau)\tilde u_0-\int_0^\tau S(\tau-s)\,f(u(s))\,ds,
\qquad 0\le \tau\le T,
\label{eq:duhamel_H1_piecewise}
\end{equation}
where $S(\tau)=e^{\tau\Delta}$ denotes the heat semigroup.

\medskip
\noindent\textbf{Step 1: $f$ is globally Lipschitz on $\R$.}
For $f=f_-$ one has $f(u)=au$ for $u\ge 0$ and $f(u)=bu$ for $u<0$. For $f=f_+$ one has $f(u)=au$ for $u\ge 0$ and $f(u)=-bu$ for $u<0$. In either case, direct inspection of the two branches yields
\[
|f(r)-f(s)|\le \max(a,b)\,|r-s|
\qquad \text{for all }r,s\in\R.
\]
Thus $f$ is globally Lipschitz on $\R$ with Lipschitz constant $\max(a,b)$, for both models.

\medskip
\noindent\textbf{Step 2: $f$ acts continuously on $H^1(\R^d)$.}
By Lemma~\ref{lem:pm_parts_H1}, for
\[
f=f_-\text{ or }f=f_+,
\]
with the explicit constant \(\sqrt{2}\max(a,b)\), one has
\[
\|f(u)\|_{H^1}\le \sqrt{2}\max(a,b)\|u\|_{H^1}
\qquad\text{for all }u\in H^1(\R^d),
\]
and
\begin{equation}
\|f(u)-f(v)\|_{H^1}\le \sqrt{2}\max(a,b)\|u-v\|_{H^1}
\qquad\text{for all }u,v\in H^1(\R^d).
\label{eq:f_H1_piecewise_Lip}
\end{equation}

\medskip
\noindent\textbf{Step 3: Definition of the fixed-point map.}
Define $\mathcal T:X_T\to X_T$ by
\[
(\mathcal Tu)(\tau):=
S(\tau)\tilde u_0-\int_0^\tau S(\tau-s)\,f(u(s))\,ds.
\]
Since the heat semigroup is bounded on $H^1(\R^d)$ with operator norm at most one,
\[
\|S(\tau)\phi\|_{H^1}\le \|\phi\|_{H^1},
\qquad \tau\ge 0,
\]
indeed, by Plancherel,
\[
\|S(\tau)\phi\|_{H^1}^2
=\int_{\R^d}(1+|\xi|^2)e^{-2\tau|\xi|^2}|\widehat\phi(\xi)|^2\,d\xi
\le \|\phi\|_{H^1}^2,
\]
we obtain for $u\in X_T$ and $0\le \tau\le T$,
\begin{align*}
\|(\mathcal Tu)(\tau)\|_{H^1}
&\le \|S(\tau)\tilde u_0\|_{H^1}
+\int_0^\tau \|S(\tau-s)f(u(s))\|_{H^1}\,ds \\
&\le \|\tilde u_0\|_{H^1}
+\int_0^\tau \|f(u(s))\|_{H^1}\,ds \\
&\le \|\tilde u_0\|_{H^1}
+\sqrt{2}\max(a,b)\int_0^\tau \|u(s)\|_{H^1}\,ds.
\end{align*}
Taking the supremum over $\tau\in[0,T]$ gives
\[
\|\mathcal Tu\|_{X_T}\le \|\tilde u_0\|_{H^1}+\sqrt{2}\max(a,b)T\|u\|_{X_T},
\]
so $\mathcal T$ maps $X_T$ into itself.

\medskip
\noindent\textbf{Step 4: Contraction estimate.}
Let $u,v\in X_T$. Using the semigroup estimate and \eqref{eq:f_H1_piecewise_Lip},
\begin{align*}
\|(\mathcal Tu)(\tau)-(\mathcal Tv)(\tau)\|_{H^1}
&\le
\int_0^\tau
\|S(\tau-s)\bigl(f(u(s))-f(v(s))\bigr)\|_{H^1}\,ds \\
&\le
\int_0^\tau
\|f(u(s))-f(v(s))\|_{H^1}\,ds \\
&\le
\sqrt{2}\max(a,b)\int_0^\tau \|u(s)-v(s)\|_{H^1}\,ds \\
&\le
\sqrt{2}\max(a,b)T\,\|u-v\|_{X_T}.
\end{align*}
Taking the supremum over $\tau\in[0,T]$ yields
\[
\|\mathcal Tu-\mathcal Tv\|_{X_T}\le \sqrt{2}\max(a,b)T\,\|u-v\|_{X_T}.
\]
Hence the fixed-point map is a contraction in the Banach space sense whenever
\[
T<\frac{1}{\sqrt{2}\max(a,b)}.
\]
This is a contraction of the auxiliary map on $X_T$, not an $L^2$ contraction of solutions.

\medskip
\noindent\textbf{Step 5: Local existence and uniqueness.}
By Banach's fixed point theorem, there exists a unique
\[
\tilde u\in C([0,T];H^1(\R^d))
\]
satisfying \eqref{eq:duhamel_H1_piecewise}. This is exactly the unique mild
solution of \eqref{eq:semilinearheat} on $[0,T]$.

\medskip
\noindent\textbf{Step 6: Continuous dependence on the initial data.}
Let $\tilde u,\tilde v\in X_T$ be the mild solutions corresponding to
initial data $\tilde u_0,\tilde v_0\in H^1(\R^d)$. Subtracting the two
Duhamel formulas and arguing as above, we obtain
\[
\|(\tilde u-\tilde v)(\tau)\|_{H^1}
\le
\|\tilde u_0-\tilde v_0\|_{H^1}
+\sqrt{2}\max(a,b)\int_0^\tau \|(\tilde u-\tilde v)(s)\|_{H^1}\,ds.
\]
Gronwall's inequality gives
\[
\|(\tilde u-\tilde v)(\tau)\|_{H^1}
\le
e^{\sqrt{2}\max(a,b)\tau}\,\|\tilde u_0-\tilde v_0\|_{H^1},
\qquad 0\le \tau\le T.
\]
Taking the supremum over $\tau\in[0,T]$ shows continuous dependence in $H^1$.

\medskip
\noindent\textbf{Step 7: Global continuation.}
The local existence time depends only on the constant \(\sqrt{2}\max(a,b)\),
not on the size of the solution. Therefore the same fixed-point argument may be
restarted at time $T$ with datum $\tilde u(T)\in H^1(\R^d)$, then at time $2T$,
and so on. Uniqueness on overlapping intervals ensures that the local solutions
patch together. Iterating in this way yields a unique global mild solution
\[
\tilde u\in C([0,\infty);H^1(\R^d)).
\]
This completes the proof.
\end{proof}

\begin{remark}[$H^1$ well-posedness is sign-agnostic]
\label{rem:H1_sign_agnostic}
The proof of Theorem~\ref{thm:H1_piecewise_wp} uses the nonlinearity only through the bounds \eqref{eq:f_piecewise_H1_bound} and \eqref{eq:f_piecewise_H1_Lip}, which by Lemma~\ref{lem:pm_parts_H1} hold identically for both $f_-$ and $f_+$. No monotonicity, sign-coercivity, or dissipativity assumption is invoked at any step. Consequently, the conclusions
\[
\tilde u \in C([0,\infty); H^1(\mathbb{R}^d)),
\qquad
\|\tilde u(\tau) - \tilde v(\tau)\|_{H^1} \le e^{\sqrt{2}\max(a,b)\tau}\|\tilde u_0 - \tilde v_0\|_{H^1},
\]
hold uniformly for the dissipative model $f_-$ and the non-dissipative model $f_+$, with the same Lipschitz constant $\sqrt{2}\max(a,b)$. The two models diverge only at the level of energy inequalities (Sections~\ref{subsec:L2_energy} and \ref{subsec:plus_L2_bound}), not at the level of $H^1$ well-posedness.
\end{remark}
