\section{The nonlinear Black-Scholes: proofs of the main results}
\label{sec:nonlinear_bs_proofs}

The heat equation theory is now transported back to the original pricing
variables.  We keep the notation of Section~\ref{sec:transform}.  Thus
\[
    \tau=T-t,\qquad
    U(\tau,S):=e^{r\tau}V(T-\tau,S),
\]
\[
    x=\log S,\qquad
    y=x+\beta\tau,\qquad
    y=Lz,\qquad
    LL^\top=\frac12Q,
\]
where
\[
    \beta_i=r-\frac12Q_{ii},\qquad i=1,\dots,d.
\]
The weight induced by the logarithmic change of variables is
\[
    \omega(S):=(S_1\cdots S_d)^{-1}.
\]
We write \(L^p_\omega\) for \(L^p((0,\infty)^d,\omega(S)\,dS)\).

\subsection{Inverse transform and norm equivalences}
\label{subsec:norm_equivalences}

For a terminal payoff \(\Phi\), the heat-side initial datum is
\begin{equation}
    \tilde u_0(z):=\Phi(e^{Lz}),
    \qquad z\in\mathbb R^d.
    \label{eq:transport_datum}
\end{equation}
Equivalently,
\[
    \Phi(S)=\tilde u_0(L^{-1}\log S).
\]

\begin{proposition}[Inverse transform]
\label{prop:inverse_transform_new}
Let \(g:\mathbb R\to\mathbb R\) be the Black-Scholes nonlinearity, and
assume that \(g\) is positively homogeneous of degree one:
\[
    g(\lambda v)=\lambda g(v)
    \qquad\text{for all }\lambda\ge0,\ v\in\mathbb R.
\]
Let \(f\) be the corresponding time-independent heat-side nonlinearity
obtained from \(g\) under this positive-homogeneity assumption.  Let
\(\tilde u\) solve the heat-side Cauchy problem
\[
    \partial_\tau\tilde u-\Delta_z\tilde u+f(\tilde u)=0,
    \qquad
    \tilde u(0,z)=\tilde u_0(z),
\]
and define
\begin{equation}
    U(\tau,S):=
    \tilde u\!\left(
        \tau,
        L^{-1}(\log S+\beta\tau)
    \right),
    \qquad
    V(t,S):=e^{-r(T-t)}U(T-t,S).
    \label{eq:inverse_map_new}
\end{equation}
Then \(V\) solves
\[
    V_t+\frac12\sum_{i,j=1}^d Q_{ij}S_iS_jV_{S_iS_j}
    +r\sum_{i=1}^d S_iV_{S_i}
    -rV-g(V)=0,
    \qquad
    V(T,S)=\Phi(S).
\]
Conversely, any solution of this Black-Scholes problem gives a heat-side
solution through the transformations of Section~\ref{sec:transform}.
\end{proposition}

\begin{proof}
The discounting step in Section~\ref{sec:transform} converts the reaction
term \(g(V)\) into the heat-side reaction
\[
    e^{r\tau}g(e^{-r\tau}U).
\]
Thus, before imposing positive homogeneity, the induced heat nonlinearity is
\[
    f(\tau,y):=e^{r\tau}g(e^{-r\tau}y).
\]
The positive homogeneity of \(g\) is used exactly at this point.  Since
\(e^{-r\tau}\ge0\),
\[
    g(e^{-r\tau}U)=e^{-r\tau}g(U),
\]
and therefore
\begin{equation}
    e^{r\tau}g(e^{-r\tau}U)=g(U).
    \label{eq:homogeneity_discount_step}
\end{equation}
Hence the heat-side nonlinearity is time-independent and is given by
\(f(y)=g(y)\) after discounting.

Now set \(\tau=T-t\), \(x=\log S\), \(y=x+\beta\tau\), and
\(z=L^{-1}y\).  Formula \eqref{eq:inverse_map_new} is precisely the inverse
of the discounting, logarithmic, moving-frame, and whitening transforms from
Section~\ref{sec:transform}.  Since \(LL^\top=\frac12Q\), the operator
\(\Delta_z\) becomes the Black-Scholes diffusion operator in \(S\), the
translation \(y=x+\beta\tau\) restores the first-order drift, and the factor
\(e^{-r\tau}\) restores the term \(-rV\).

At \(\tau=0\),
\[
    U(0,S)=\tilde u_0(L^{-1}\log S)=\Phi(S)
\]
by \eqref{eq:transport_datum}.  Hence \(V(T,S)=\Phi(S)\).  Each change of
variables is invertible, so the correspondence is one-to-one.
\end{proof}

\begin{lemma}[Norm equivalences]
\label{lem:norm_equivalences_new}
Let \(1\le p<\infty\).  For \(U\) and \(\tilde u\) related by
\eqref{eq:inverse_map_new},
\begin{equation}
    \|U(\tau)\|_{L^p_\omega}^p
    =
    |\det L|\,\|\tilde u(\tau)\|_{L^p(\mathbb R^d)}^p.
    \label{eq:norm_equiv_Lp}
\end{equation}
In particular, at \(\tau=0\),
\begin{equation}
    \|\Phi\|_{L^p_\omega}^p
    =
    |\det L|\,\|\tilde u_0\|_{L^p(\mathbb R^d)}^p.
    \label{eq:datum_norm_equiv_Lp}
\end{equation}
Moreover, with
\[
    D_SU:=(S_1\partial_{S_1}U,\dots,S_d\partial_{S_d}U),
\]
one has
\begin{equation}
    \int_{(0,\infty)^d}
    (D_SU)^\top\!\left(\frac12Q\right)(D_SU)\,\omega(S)\,dS
    =
    |\det L|\,\|\nabla_z\tilde u(\tau)\|_{L^2(\mathbb R^d)}^2.
    \label{eq:norm_equiv_H1}
\end{equation}
Consequently,
\[
    \Phi\in L^2_\omega
    \quad\Longleftrightarrow\quad
    \tilde u_0\in L^2(\mathbb R^d),
\]
and
\[
    \Phi\in H^1_{\omega,Q}
    \quad\Longleftrightarrow\quad
    \tilde u_0\in H^1(\mathbb R^d),
\]
where
\[
    H^1_{\omega,Q}
    :=
    \left\{
    W\in L^2_\omega:
    \int_{(0,\infty)^d}
    (D_SW)^\top\!\left(\frac12Q\right)(D_SW)\,\omega\,dS<\infty
    \right\}.
\]
\end{lemma}

\begin{proof}
The change \(S_i=e^{x_i}\) gives \(dx=\omega(S)\,dS\).  The translation
\(y=x+\beta\tau\) has unit Jacobian, and \(y=Lz\) gives
\(dy=|\det L|\,dz\).  Hence
\[
\begin{aligned}
    \|U(\tau)\|_{L^p_\omega}^p
    &=\int_{(0,\infty)^d}|U(\tau,S)|^p\,\omega(S)\,dS  \\
    &=\int_{\mathbb R^d}|u(\tau,y)|^p\,dy
      =|\det L|\int_{\mathbb R^d}|\tilde u(\tau,z)|^p\,dz.
\end{aligned}
\]
This proves \eqref{eq:norm_equiv_Lp}; \eqref{eq:datum_norm_equiv_Lp}
follows by setting \(\tau=0\).

For the gradient identity, \(\tilde u(\tau,z)=u(\tau,Lz)\) gives
\[
    \nabla_z\tilde u=L^\top\nabla_yu.
\]
Changing variables from \(z\) to \(y\),
\[
    |\det L|\,\|\nabla_z\tilde u\|_{L^2}^2
    =
    \int_{\mathbb R^d}
    (\nabla_yu)^\top(LL^\top)(\nabla_yu)\,dy.
\]
Since \(LL^\top=\frac12Q\), \(y=x+\beta\tau\), and
\[
    \partial_{x_i}U(\tau,e^x)=S_i\partial_{S_i}U(\tau,S),
\]
we have \(\nabla_yu=D_SU\).  Changing from \(x\) back to \(S\) gives
\eqref{eq:norm_equiv_H1}.
\end{proof}


\begin{lemma}[Transport of heat-side estimates to weighted Black-Scholes variables]
\label{lem:transport_weighted_estimates}
Assume \(g\) is positively homogeneous of degree one, let \(f\) be the induced heat-side nonlinearity, and let \(\tilde u\), \(U\), and \(V\) be related by Proposition~\ref{prop:inverse_transform_new}. For any sufficiently regular \(W:(0,\infty)^d\to\mathbb R\), define
\[
E_Q[W]:=
\int_{(0,\infty)^d}
(D_SW)^\top\!\left(\frac12Q\right)(D_SW)\,\omega\,dS.
\]
Then:
\begin{enumerate}[label=(\roman*)]
\item for \(p\in\{1,2\}\), any heat-side estimate of the form
\[
\|\tilde u(\tau)\|_{L^p(\mathbb R^d)}
\le
A(\tau)\|\tilde u_0\|_{L^p(\mathbb R^d)}
\]
transports to
\[
\|U(\tau)\|_{L^p_\omega}
\le
A(\tau)\|\Phi\|_{L^p_\omega},
\qquad
\|V(t)\|_{L^p_\omega}
\le
e^{-r(T-t)}A(T-t)\|\Phi\|_{L^p_\omega};
\]
\item if \(\tilde u\in C([0,T];H^1(\mathbb R^d))\), then \(U\in C([0,T];H^1_{\omega,Q})\). More generally, any heat-side gradient estimate of the form
\[
\|\nabla_z\tilde u(\tau)\|_{L^2(\mathbb R^d)}
\le
B(\tau)\|\tilde u_0\|_{L^2(\mathbb R^d)}
\]
gives
\[
E_Q[U(\tau)]^{1/2}
\le
B(\tau)\|\Phi\|_{L^2_\omega};
\]
\item one has the reaction-term identity
\[
\int_{(0,\infty)^d}g(U(\tau,S))U(\tau,S)\,\omega(S)\,dS
=
|\det L|\int_{\mathbb R^d}f(\tilde u(\tau,z))\tilde u(\tau,z)\,dz.
\]
Consequently, any heat-side identity or inequality involving only the quantities \(\|\tilde u\|_{L^1}\), \(\|\tilde u\|_{L^2}\), \(\|\nabla_z\tilde u\|_{L^2}\), and \(\int f(\tilde u)\tilde u\) transports to the weighted variables after multiplying by \(|\det L|\).
\end{enumerate}
\end{lemma}

\begin{proof}
Part~(i) is immediate from \eqref{eq:norm_equiv_Lp}, \eqref{eq:datum_norm_equiv_Lp}, and the relation \(V(t)=e^{-r(T-t)}U(T-t)\). Part~(ii) follows from \eqref{eq:norm_equiv_H1} together with the \(p=2\) case of part~(i). For part~(iii), the inverse map gives \(\tilde u(\tau,z)=U(\tau,S)\) pointwise, and positive homogeneity identifies the heat-side nonlinearity with the discounted Black-Scholes nonlinearity. Using \(dz=|\det L|^{-1}\omega(S)\,dS\) yields the claimed identity.
\end{proof}



\subsection{Piecewise-linear models}

We have the following.

\begin{theorem}[Weighted well-posedness and \(H^1\) regularization]
\label{thm:BS_discounted_core}
Let
\[
    g_-(v)=a v^+-b v^-,
    \qquad
    g_+(v)=a v^+ + b v^-,
    \qquad a,b\ge0.
\]
For either choice \(g=g_-\) or \(g=g_+\), assume
\[
    \Phi\in L^2_\omega((0,\infty)^d).
\]
Then the nonlinear Black-Scholes problem with terminal datum \(\Phi\)
admits a unique discounted mild solution
\[
    U\in C([0,T];L^2_\omega).
\]
Equivalently,
\[
    V(t,S)=e^{-r(T-t)}U(T-t,S)
    \in C([0,T];L^2_\omega).
\]
The solution depends Lipschitz continuously on the terminal datum on bounded
time intervals.

If in addition \(\Phi\in H^1_{\omega,Q}\), then
\[
    U\in C([0,T];H^1_{\omega,Q}).
\]
If only \(\Phi\in L^2_\omega\), then
\[
    U(\tau,\cdot)\in H^1_{\omega,Q}
    \qquad\text{for every }\tau>0.
\]
More precisely,
\begin{equation}
\begin{aligned}
    &\left(
    \int_{(0,\infty)^d}
    (D_SU(\tau))^\top\!\left(\frac12Q\right)(D_SU(\tau))\,
    \omega\,dS
    \right)^{1/2}                                      \\
    &\qquad\le
    C\tau^{-1/2}\|\Phi\|_{L^2_\omega}
    +
    C\|\Phi\|_{L^2_\omega}\int_0^\tau(\tau-s)^{-1/2}e^{cs}\,ds ,
\end{aligned}
\label{eq:BS_H1_smoothing}
\end{equation}
with \(c=0\) for \(g_-\) and \(c=b\) for \(g_+\).
\end{theorem}

\begin{proof}
By Lemma~\ref{lem:norm_equivalences_new}, \(\Phi\in L^2_\omega\) if and only if \(\tilde u_0\in L^2(\mathbb R^d)\). Positive homogeneity sends \(g_-\) and \(g_+\) to the heat-side nonlinearities
\[
f_-(u)=a u^+-b u^-,
\qquad
f_+(u)=a u^+ + b u^-,
\]
and both are globally Lipschitz. Theorem~\ref{thm:L2_global_wp} therefore gives a unique global heat-side mild solution \(\tilde u\in C([0,T];L^2(\mathbb R^d))\), with Lipschitz dependence on the initial datum. Lemma~\ref{lem:transport_weighted_estimates}(i) transports these conclusions to \(U\in C([0,T];L^2_\omega)\) and \(V(t)=e^{-r(T-t)}U(T-t)\).

If \(\Phi\in H^1_{\omega,Q}\), then Lemma~\ref{lem:norm_equivalences_new} gives \(\tilde u_0\in H^1(\mathbb R^d)\). Theorem~\ref{thm:H1_piecewise_wp} applies to both piecewise-linear models, and Lemma~\ref{lem:transport_weighted_estimates}(ii) yields \(U\in C([0,T];H^1_{\omega,Q})\).

If only \(\Phi\in L^2_\omega\), then the shared smoothing estimate \eqref{eq:H1_smoothing_explicit} applies with \(\varphi(s)\equiv 1\) in the dissipative case by \eqref{eq:L2_decay_general}, and with \(\varphi(s)=e^{bs}\) in the plus model by \eqref{eq:plus_L2_gronwall}. Lemma~\ref{lem:transport_weighted_estimates}(ii) then gives \eqref{eq:BS_H1_smoothing}.
\end{proof}

\begin{proposition}[Energy identity]
\label{prop:BS_energy_identity}
Let \(g\) be a positively homogeneous Black-Scholes nonlinearity, let \(f\) be the induced heat-side nonlinearity, and let \(U\) be the discounted Black-Scholes unknown corresponding to a sufficiently smooth heat-side solution \(\tilde u\). Then \(U\) satisfies the weighted identity
\begin{equation}
    \frac12\frac{d}{d\tau}\|U(\tau)\|_{L^2_\omega}^2
    +
    \int_{(0,\infty)^d}
    (D_SU)^\top\!\left(\frac12Q\right)(D_SU)\,\omega\,dS
    +
    \int_{(0,\infty)^d}g(U)U\,\omega\,dS
    =
    0.
    \label{eq:BS_energy_identity}
\end{equation}
\end{proposition}

\begin{proof}
The heat-side identity is
\[
    \frac12\frac{d}{d\tau}\|\tilde u(\tau)\|_{L^2}^2
    +
    \|\nabla_z\tilde u(\tau)\|_{L^2}^2
    +
    \int_{\mathbb R^d}f(\tilde u)\tilde u\,dz
    =
    0.
\]
Apply Lemma~\ref{lem:transport_weighted_estimates}(iii) together with Lemma~\ref{lem:norm_equivalences_new} to transport the three terms in this identity.
\end{proof}

\subsection{Dissipative model}

In this subsection
\[
    g_-(v)=a v^+-b v^-,
    \qquad a,b\ge0,
\]
and the induced heat-side nonlinearity is
\[
    f_-(u)=a u^+-b u^-.
\]

\begin{theorem}[Dissipative weighted energy estimate]
\label{thm:BS_dissipative_energy}
Let \(\Phi\in L^2_\omega\), and let \(U\) be the discounted solution
corresponding to \(g_-\).  Then, for every \(\tau\in[0,T]\),
\begin{equation}
    \|U(\tau)\|_{L^2_\omega}
    \le
    \|\Phi\|_{L^2_\omega},
    \label{eq:U_L2_contraction_theorem}
\end{equation}
and
\begin{equation}
\begin{aligned}
    \frac12\|U(\tau)\|_{L^2_\omega}^2
    &+
    \int_0^\tau\!\!\int_{(0,\infty)^d}
    (D_SU)^\top\!\left(\frac12Q\right)(D_SU)\,\omega\,dS\,ds \\
    &+
    \int_0^\tau\!\!\int_{(0,\infty)^d}
    g_-(U)U\,\omega\,dS\,ds
    \le
    \frac12\|\Phi\|_{L^2_\omega}^2 .
\end{aligned}
\label{eq:U_weighted_energy_theorem}
\end{equation}
Consequently,
\begin{equation}
    \|V(t)\|_{L^2_\omega}
    \le
    e^{-r(T-t)}\|\Phi\|_{L^2_\omega}.
    \label{eq:V_weighted_L2_theorem}
\end{equation}
\end{theorem}

\begin{proof}
By Lemma~\ref{lem:transport_weighted_estimates}(iii), the heat-side dissipation estimate \eqref{eq:L2_dissipation_general} becomes exactly \eqref{eq:U_weighted_energy_theorem}. Dropping the nonnegative terms gives \eqref{eq:U_L2_contraction_theorem}. The estimate for \(V\) follows from \(V(t)=e^{-r(T-t)}U(T-t)\).
\end{proof}

\begin{theorem}[Contraction and dependence]
\label{thm:BS_original_core}
Let \(U_1,U_2\) be two discounted solutions of the dissipative model with
terminal data \(\Phi_1,\Phi_2\in L^2_\omega\).  Then
\begin{equation}
    \|U_1(\tau)-U_2(\tau)\|_{L^2_\omega}
    \le
    \|\Phi_1-\Phi_2\|_{L^2_\omega},
    \qquad 0\le\tau\le T.
    \label{eq:BS_L2_contraction}
\end{equation}
Equivalently,
\[
    \|V_1(t)-V_2(t)\|_{L^2_\omega}
    \le
    e^{-r(T-t)}\|\Phi_1-\Phi_2\|_{L^2_\omega}.
\]
\end{theorem}

\begin{proof}
Apply Lemma~\ref{lem:transport_weighted_estimates}(i) with \(p=2\) to the heat-side contraction estimate \eqref{eq:L2_contraction}, applied to \(\tilde u_1-\tilde u_2\). The estimate for \(V_1-V_2\) then follows from \(V_i(t)=e^{-r(T-t)}U_i(T-t)\).
\end{proof}

\begin{theorem}[Weighted \(L^1\) contraction and Gagliardo-Nirenberg decay]
\label{thm:BS_dissipative_GN}
Assume \(g=g_-\) and
\[
    \Phi\in L^1_\omega((0,\infty)^d)\cap L^2_\omega((0,\infty)^d).
\]
Then
\[
    \|U(\tau)\|_{L^1_\omega}
    \le
    \|\Phi\|_{L^1_\omega}.
\]
Moreover, if \(C_N\) is the heat-side Gagliardo-Nirenberg constant, set
\[
    C_{N,Q}:=C_N|\det L|^{-2/d}.
\]
Then
\begin{equation}
    \|U(\tau)\|_{L^2_\omega}^2
    \le
    \left(
    \|\Phi\|_{L^2_\omega}^{-4/d}
    +
    \frac{4}{dC_{N,Q}}
    \|\Phi\|_{L^1_\omega}^{-4/d}\tau
    \right)^{-d/2}.
    \label{eq:U_weighted_decay_theorem}
\end{equation}
Consequently, for \(t<T\),
\begin{equation}
    \|V(t)\|_{L^2_\omega}
    \le
    e^{-r(T-t)}
    \left(
    \|\Phi\|_{L^2_\omega}^{-4/d}
    +
    \frac{4}{dC_{N,Q}}
    \|\Phi\|_{L^1_\omega}^{-4/d}(T-t)
    \right)^{-d/4}.
    \label{eq:V_weighted_decay_theorem}
\end{equation}
\end{theorem}

\begin{proof}
By Lemma~\ref{lem:transport_weighted_estimates}(i) with \(p=1\), the heat-side \(L^1\) contraction \eqref{eq:L1_piecewise} yields
\[
\|U(\tau)\|_{L^1_\omega}\le \|\Phi\|_{L^1_\omega}.
\]

With \(E_Q\) as in Lemma~\ref{lem:transport_weighted_estimates}, the heat-side Gagliardo-Nirenberg inequality
\[
\|\tilde u\|_{L^2}^{2+4/d}
\le
C_N\|\nabla_z\tilde u\|_{L^2}^2\|\tilde u\|_{L^1}^{4/d}
\]
and Lemma~\ref{lem:transport_weighted_estimates}(i)--(ii) give
\[
\|U\|_{L^2_\omega}^{2+4/d}
\le
C_N|\det L|^{-2/d}E_Q[U]\|U\|_{L^1_\omega}^{4/d}.
\]
Hence \(C_{N,Q}=C_N|\det L|^{-2/d}\). Combining this weighted inequality with \eqref{eq:U_weighted_energy_theorem}, the weighted \(L^1_\omega\) contraction above, and the same ODE argument as in the heat-side proof of \eqref{eq:piecewise_GN_final}, gives \eqref{eq:U_weighted_decay_theorem}. The estimate for \(V\) follows from \(V(t)=e^{-r(T-t)}U(T-t)\).
\end{proof}

\subsection{Non-dissipative model}

In this subsection
\[
    g_+(v)=a v^+ + b v^-,
    \qquad a,b\ge0,
\]
and the induced heat-side nonlinearity is
\[
    f_+(u)=a u^+ + b u^-.
\]
This model has the shared Lipschitz and piecewise-linear structure, but it
does not have the dissipative sign condition used in the preceding subsection.

\begin{theorem}[Black-Scholes-side bounds for the non-dissipative model]
\label{thm:BS_original_plus}
Let \(\Phi\in L^2_\omega\).  Then the plus-model Black-Scholes problem
admits a unique discounted solution
\[
     U\in C([0,T];L^2_\omega).
\]
Moreover,
\begin{equation}
    \| U(\tau)\|_{L^2_\omega}^2
    \le
    e^{2b\tau}\|\Phi\|_{L^2_\omega}^2,
    \qquad 0\le\tau\le T,
    \label{eq:U_plus_weighted_L2_theorem}
\end{equation}
and hence
\begin{equation}
    \|V(t)\|_{L^2_\omega}^2
    \le
    e^{-2(r-b)(T-t)}\|\Phi\|_{L^2_\omega}^2.
    \label{eq:V_plus_weighted_L2_theorem}
\end{equation}

For every \(\tau>0\),
\[
     U(\tau,\cdot)\in H^1_{\omega,Q},
\]
and
\begin{equation}
\begin{aligned}
    &\left(
    \int_{(0,\infty)^d}
    (D_S U(\tau))^\top\!\left(\frac12Q\right)(D_S U(\tau))
    \,\omega\,dS
    \right)^{1/2}                                      \\
    &\qquad\le
    C\tau^{-1/2}\|\Phi\|_{L^2_\omega}
    +
    C\max(a,b)
    \int_0^\tau(\tau-s)^{-1/2}e^{bs}\|\Phi\|_{L^2_\omega}\,ds .
\end{aligned}
\label{eq:U_plus_weighted_smoothing}
\end{equation}

If, in addition,
\[
    \Phi\in L^1_\omega\cap L^2_\omega,
\]
then, with \(C_{N,Q}=C_N|\det L|^{-2/d}\),
\begin{equation}
    \| U(\tau)\|_{L^2_\omega}^2
    \le
    e^{2b\tau}
    \left(
    \|\Phi\|_{L^2_\omega}^{-4/d}
    +
    \frac{4}{dC_{N,Q}}
    \|\Phi\|_{L^1_\omega}^{-4/d}\tau
    \right)^{-d/2},
    \label{eq:U_plus_GN_weighted}
\end{equation}
and therefore, for \(t<T\),
\begin{equation}
    \|V(t)\|_{L^2_\omega}
    \le
    e^{-(r-b)(T-t)}
    \left(
    \|\Phi\|_{L^2_\omega}^{-4/d}
    +
    \frac{4}{dC_{N,Q}}
    \|\Phi\|_{L^1_\omega}^{-4/d}(T-t)
    \right)^{-d/4}.
    \label{eq:V_plus_GN_theorem}
\end{equation}
The estimates \eqref{eq:U_plus_GN_weighted} and
\eqref{eq:V_plus_GN_theorem} are a priori bounds with an exponential factor;
they are not dissipative decay statements.
\end{theorem}

\begin{proof}
The well-posedness statement is already contained in Theorem~\ref{thm:BS_discounted_core}.

Applying Lemma~\ref{lem:transport_weighted_estimates}(i) with \(p=2\) to \eqref{eq:plus_L2_gronwall} gives \eqref{eq:U_plus_weighted_L2_theorem}, and the bound for \(V\) follows from the same part of the lemma.

Applying Lemma~\ref{lem:transport_weighted_estimates}(ii) to Proposition~\ref{prop:plus_H1_smoothing} gives \eqref{eq:U_plus_weighted_smoothing}.

If \(\Phi\in L^1_\omega\cap L^2_\omega\), then Lemma~\ref{lem:transport_weighted_estimates}(i) gives
\[
\|\tilde u_0\|_{L^2}=|\det L|^{-1/2}\|\Phi\|_{L^2_\omega},
\qquad
\|\tilde u_0\|_{L^1}=|\det L|^{-1}\|\Phi\|_{L^1_\omega}.
\]
Substituting these identities into \eqref{eq:plus_GN_final} and multiplying by \(|\det L|\) yields \eqref{eq:U_plus_GN_weighted} with \(C_{N,Q}=C_N|\det L|^{-2/d}\). The estimate for \(V\) again follows from \(V(t)=e^{-r(T-t)}U(T-t)\).
\end{proof}

\paragraph{Black-Scholes interpretation.}

For the non-dissipative piecewise-linear nonlinearity
\[
f(u)=a\,u^+ + b\,u^-,
\qquad a,b\ge 0,
\]

the heat-side asymptotic estimate \eqref{eq:plus_GN_asymptotic} gives
\begin{equation}
\|\tilde u(\tau)\|_{L^2(\R^d)}^2
\lesssim
e^{2b\tau}\,\|\tilde u_0\|_{L^1(\R^d)}^2\,\tau^{-d/2},
\qquad \tau>0.
\label{eq:GN_piecewise_heat}
\end{equation}
Transporting this bound back to the discounted Black-Scholes variable \(U\), one obtains
\begin{equation}
\|U(\tau)\|_{L^2_w((0,\infty)^d)}^2
\lesssim
e^{2b\tau}\,\|U(0)\|_{L^1_w((0,\infty)^d)}^2\,\tau^{-d/2},
\qquad \tau>0,
\label{eq:GN_piecewise_U}
\end{equation}
or equivalently
\begin{equation}
\|U(\tau)\|_{L^2_w((0,\infty)^d)}
\lesssim
e^{b\tau}\,\|U(0)\|_{L^1_w((0,\infty)^d)}\,\tau^{-d/4}.
\label{eq:GN_piecewise_U_sqrt}
\end{equation}

Since \(U(0,S)=V(T,S)=\Phi(S)\), we may rewrite \eqref{eq:GN_piecewise_U} as
\begin{equation}
\|U(\tau)\|_{L^2_w((0,\infty)^d)}^2
\lesssim
e^{2b\tau}\,\|\Phi\|_{L^1_w((0,\infty)^d)}^2\,\tau^{-d/2}.
\label{eq:GN_piecewise_U_payoff}
\end{equation}

We now return to the original option price \(V\). By construction,
\[
V(t,S)=e^{-r(T-t)}U(T-t,S),
\]
hence, with \(\tau=T-t\),
\[
\|V(t)\|_{L^2_w}
=
e^{-r\tau}\,\|U(\tau)\|_{L^2_w}.
\]
Combining this with \eqref{eq:GN_piecewise_U_sqrt}, we obtain
\begin{equation}
\boxed{
\|V(t)\|_{L^2_w((0,\infty)^d)}
\lesssim
e^{-(r-b)(T-t)}\,
\|\Phi\|_{L^1_w((0,\infty)^d)}\,
(T-t)^{-d/4}.
}
\label{eq:financial_piecewise_main}
\end{equation}
Equivalently,
\begin{equation}
\boxed{
\|V(t)\|_{L^2_w((0,\infty)^d)}^2
\lesssim
e^{-2(r-b)(T-t)}\,
\|\Phi\|_{L^1_w((0,\infty)^d)}^2\,
(T-t)^{-d/2}.
}
\label{eq:financial_piecewise_main_sq}
\end{equation}

Estimate \eqref{eq:financial_piecewise_main} shows that, in the weighted \(L^2\)-norm naturally induced by the logarithmic transform, the option price is governed by two competing mechanisms.

\begin{itemize}
\item The factor
\[
e^{-r(T-t)}
\]
is the usual exponential damping produced by discounting at the risk-free rate \(r\).

\item The factor
\[
e^{b(T-t)}
\]
comes from the negative branch of the piecewise-linear funding term \(f(u)=a u^+ + b u^-\). In the energy calculation, this branch contributes with the unfavorable sign
\[
f(u)u=a(u^+)^2-b(u^-)^2,
\]
and therefore weakens the dissipative effect of the diffusion.
\end{itemize}

Thus the estimate is controlled by the \emph{effective rate}
\[
r-b.
\]
This leads to three regimes.

\medskip
\noindent\textbf{(i) The case \(r>b\).}
If the discount rate dominates the adverse contribution of the funding term, then
\[
e^{-(r-b)(T-t)}
\]
is a genuine damping factor. In this regime, the weighted \(L^2\)-norm of the option price is bounded by an exponentially decreasing factor multiplied by the polynomial smoothing term \((T-t)^{-d/4}\). Hence the estimate still reflects a net stabilizing effect as one moves away from maturity.

\medskip
\noindent\textbf{(ii) The case \(r=b\).}
If the two effects exactly balance, then the exponential factors cancel and one is left with the purely polynomial estimate
\[
\|V(t)\|_{L^2_w}
\lesssim
\|\Phi\|_{L^1_w}\,(T-t)^{-d/4}.
\]
In this borderline regime, discounting no longer improves the bound beyond the parabolic smoothing already present in the heat flow.

\medskip
\noindent\textbf{(iii) The case \(b>r\).}
If the negative-side funding contribution exceeds the discount rate, then the exponential factor becomes
\[
e^{(b-r)(T-t)},
\]
and the estimate allows growth as one moves backward from maturity. This does not mean that the solution necessarily blows up; rather, it means that the present argument no longer yields a decaying a priori bound in the weighted \(L^2\)-norm. In other words, the funding asymmetry may overcome the stabilizing effect of discounting at the level of this estimate.

\medskip
\medskip
\noindent\textbf{Financial meaning.}
Unlike the dissipative model \(g_-\), the non-dissipative term \(g_+\) does
not arise from a strict no-arbitrage replication argument, such as those
developed by \cite{Piterbarg2010}, or from the bilateral XVA setting of
\cite{BurgardKjaer2011}. Rather, it should be interpreted as a reduced-form
modification encoding the strength of an asymmetric correction applied to the
negative exposure.

The economic interpretation becomes more concrete when we separately examine
the positive and negative branches of the term. On the positive side,
\(g_+(V)=aV^+\), the model behaves exactly like the dissipative model \(g_-\):
positive receivables require financing, which reduces the present value. On
the other hand, the negative exposure term \(g_+(V)=bV^-\) acts in the
opposite direction compared to \(g_-\). Whereas \(g_-\) dampens negative
exposures and drives \(V\) back toward zero, the term \(g_+(V)=bV^-\ge 0\)
enters the pricing equation with sign \(-g_+(V)\le 0\), which drives \(V\)
further negative rather than toward zero.

As discussed above, this term should be interpreted not as a direct
replication-based funding adjustment, but rather as a reduced-form
credit-risk, regulatory, or stress-test correction. Mathematically, it tests
which estimates survive when the sign of the negative branch is flipped. The
effect of this sign flip is that the usual exponential decay driven by
discounting at rate \(r\) is weakened to an effective rate \(r-b\). When
\(b<r\), discounting still dominates and the estimate exhibits decay in the
weighted \(L^2\)-norm. When \(b>r\), this decay is no longer guaranteed at
the level of the estimate, although the solution itself remains globally
bounded by Proposition~\ref{prop:plus_L2_gronwall}. Thus, the parameter \(b\)
measures how strongly the negative-branch correction counteracts the influence
of discounting.

\begin{remark}
Estimate \eqref{eq:plus_GN_final} is not a decay estimate in the usual sense.
The polynomial factor \(\tau^{-d/2}\) is multiplied by the exponential factor
\(e^{2b\tau}\), so no genuine algebraic decay follows unless \(b=0\). The
correct interpretation is that diffusion still provides smoothing, but the
negative branch of the nonlinearity introduces a competing growth mechanism.
\end{remark}


