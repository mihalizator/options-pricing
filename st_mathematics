\section{Dissipative Model \texorpdfstring{$f_-(u)=a u^+ - b u^-$}{f-}}
\label{sec:dissipative_model}

The previous section deliberately avoided sign assumptions. We now add the extra structure that is specific to the core funding model and derive the stronger consequences that it permits: energy dissipation, contraction, comparison, and long-time decay. In this section only, we assume
\begin{equation}
f_-:\R\to\R,\qquad f_-(0)=0,\qquad f_- \text{ is nondecreasing},
\label{eq:f_monotone}
\end{equation}
and, for the piecewise-linear funding model,
\begin{equation}
\boxed{
f_-(u)=a\,u^+ - b\,u^-,
\qquad a,b\ge 0.
}
\label{eq:f_piecewise_linear}
\end{equation}

\begin{lemma}[Elementary dissipation fact]
\label{lem:elementary_dissipation}
Assume \eqref{eq:f_monotone}. Then $f_-(s)s\ge 0$ for all $s\in\R$.
\end{lemma}

\begin{proof}
If $s\ge0$, then monotonicity and $f_-(0)=0$ give $f_-(s)\ge0$, hence
$f_-(s)s\ge0$. If $s\le0$, then monotonicity gives $f_-(s)\le0$, so again
$f_-(s)s\ge0$.
\end{proof}

\subsection{\texorpdfstring{$L^2$}{L2} energy identity and dissipation}
\label{subsec:L2_energy}

Assume $\tilde u$ is a sufficiently smooth solution of \eqref{eq:semilinearheat} decaying at infinity.
Multiplying \eqref{eq:semilinearheat} by $\tilde u$ and integrating over $\R^d$ yields
\begin{align}
0
&=\int_{\R^d} \tilde u\,\partial_\tau \tilde u\,dz
-\int_{\R^d} \tilde u\,\Delta \tilde u\,dz
+\int_{\R^d} f_-(\tilde u)\tilde u\,dz \nonumber\\
&=\frac12\frac{d}{d\tau}\|\tilde u(\tau)\|_{L^2}^2
+\|\nabla \tilde u(\tau)\|_{L^2}^2
+\int_{\R^d} f_-(\tilde u(\tau,z))\,\tilde u(\tau,z)\,dz .
\label{eq:L2_energy_general}
\end{align}
Since $f_-(s)s\ge 0$, the last term is nonnegative, hence
\begin{equation}
\boxed{
\frac12\frac{d}{d\tau}\|\tilde u(\tau)\|_{2}^2 + \|\nabla \tilde u(\tau)\|_{L^2}^2 \le 0,
\qquad
\|\tilde u(\tau)\|_{L^2}\le \|\tilde u_0\|_{L^2}.
}
\label{eq:L2_decay_general}
\end{equation}
Financially, this inequality states that the discounted exposure cannot grow over time under the dissipative funding specification. In reduced-form terms, it expresses a no-arbitrage-type constraint: once funding costs are accounted for, the model does not permit systematic amplification of discounted mark-to-market value.
Moreover, integrating \eqref{eq:L2_energy_general} from $0$ to $\tau$ gives the dissipation estimate
\begin{equation}
\boxed{
\frac12\|\tilde u(\tau)\|_{L^2}^2
+\int_0^\tau \|\nabla \tilde u(s)\|_{L^2}^2\,ds
+\int_0^\tau\int_{\R^d} f_-(\tilde u)\tilde u\,dz\,ds
=\frac12\|\tilde u_0\|_{L^2}^2.
}
\label{eq:L2_dissipation_general}
\end{equation}
\noindent This completes the formal derivation of the $L^2$ energy identity.




\subsection{\texorpdfstring{$L^2$}{L2} contraction (uniqueness and stability)}
\label{subsec:L2_contraction}

Let $\tilde u,\tilde v$ be two (smooth) solutions of \eqref{eq:semilinearheat} with data
$\tilde u_0,\tilde v_0\in L^2(\R^d)$ and set $w=\tilde u-\tilde v$. Then
\[
\partial_\tau w-\Delta w + \big(f_-(\tilde u)-f_-(\tilde v)\big)=0.
\]
Multiply by $w$ and integrate:
\begin{equation}
\frac12\frac{d}{d\tau}\|w(\tau)\|_{L^2}^2 + \|\nabla w(\tau)\|_{L^2}^2
+\int_{\R^d} \big(f_-(\tilde u)-f_-(\tilde v)\big)\,(\tilde u-\tilde v)\,dz
=0.
\label{eq:contraction_identity}
\end{equation}
By monotonicity, $(f_-(a)-f_-(b))(a-b)\ge 0$ for all $a,b$, so the last term is nonnegative and
\begin{equation}
\boxed{
\| \tilde u(\tau)-\tilde v(\tau)\|_{L^2}\le \|\tilde u_0-\tilde v_0\|_{L^2},
\qquad \tau\ge 0.
}
\label{eq:L2_contraction}
\end{equation}
This yields uniqueness in the natural $L^2$ energy class and Lipschitz continuous dependence on initial data.
For mild solutions, this inequality is justified by approximating
$\tilde u$ and $\tilde v$ by smooth solutions obtained from regularized initial data, deriving \eqref{eq:L2_contraction}
at the smooth level, and passing to the limit using strong $L^2$
convergence of the approximation scheme;
\begin{comment}
see \cite[Ch.~7]{EvansPDE}.
\end{comment}

