\section{The non-dissipative model \texorpdfstring{$f_+(u)=a u^+ + b u^-$}{f+(u)=a u+ + b u-}}
\label{sec:plus_model}

We now turn to the non-dissipative extension model. The nonlinearity \(f_+\) has the same global Lipschitz and piecewise-linear regularity as \(f_-\), so the shared well-posedness and parabolic regularization theory continue to apply. What fails, however, is the sign-coercive structure underlying the dissipative model. In particular, one no longer expects \(L^2\)-contraction, comparison principles, or genuine decay estimates. The purpose of this section is therefore to identify precisely which conclusions survive in the absence of dissipativity, and to distinguish them from the stronger results available for \(f_-\).

We study the semilinear heat equation
\begin{equation}
\boxed{
\partial_\tau u - \Delta u + f_+(u)=0,
\qquad (\tau,z)\in (0,\infty)\times \mathbb{R}^d,
}
\label{eq:plus_semilinear_heat}
\end{equation}
with initial condition
\[
u(0,z)=u_0(z),
\qquad z\in\mathbb{R}^d,
\]
where
\begin{equation}
\boxed{
f_+(u):=a\,u^+ + b\,u^-,
\qquad a,b\ge 0,
\qquad
u^+:=\max(u,0),\quad u^-:=\max(-u,0).
}
\label{eq:plus_nonlinearity}
\end{equation}

Unlike the dissipative model \(f_-(u)=a u^+-b u^-\), the present nonlinearity is not sign-coercive. Indeed,
\begin{equation}
f_+(u)\,u
=
\begin{cases}
a u^2, & u\ge 0,\\[1mm]
-b u^2, & u<0,
\end{cases}
\label{eq:plus_sign_structure}
\end{equation}
so in particular
\begin{equation}
f_+(u)\,u \ge -b\,|u|^2
\qquad\text{for all }u\in\mathbb{R},
\label{eq:plus_lower_bound_fu}
\end{equation}
but \(f_+(u)u\) is not nonnegative in general. Consequently, the energy-decay method available for the dissipative model does not apply here in the same form. The correct framework is instead based on global Lipschitz continuity, semigroup estimates, and Gr\"onwall bounds.

\subsection{Basic properties of the nonlinearity}
\label{subsec:plus_basic_properties}

We collect the elementary properties of \(f_+\).

\begin{lemma}[Basic properties of \(f_+\)]
\label{lem:plus_basic_properties}
Let \(f_+\) be given by \eqref{eq:plus_nonlinearity}. Then:
\begin{enumerate}
    \item \(f_+(0)=0\);
    \item \(f_+\) is globally Lipschitz on \(\mathbb{R}\), with
    \[
    |f_+(u)-f_+(v)|\le L\,|u-v|,
    \qquad L:=\max(a,b);
    \]
    \item \(f_+\) has at most linear growth:
    \[
    |f_+(u)|\le L\,|u|
    \qquad\text{for all }u\in\mathbb{R};
    \]
    \item \(f_+\) satisfies the lower bound
    \[
    f_+(u)\,u\ge -b\,|u|^2
    \qquad\text{for all }u\in\mathbb{R}.
    \]
\end{enumerate}
\end{lemma}

\begin{proof}
The identity \(f_+(0)=0\) is immediate. Since \(u\mapsto u^+\) and \(u\mapsto u^-\) are both 1-Lipschitz on \(\mathbb{R}\),
\[
|f_+(u)-f_+(v)|
\le a\,|u^+-v^+| + b\,|u^-v^-|
\le (a+b)|u-v|.
\]
More precisely, by considering separately the regions \(u,v\ge 0\), \(u,v\le 0\), and mixed signs, one obtains the sharper bound with \(L=\max(a,b)\). The linear-growth estimate follows from
\[
|f_+(u)| \le a\,u^+ + b\,u^- \le \max(a,b)(u^+ + u^-)=\max(a,b)|u|.
\]
Finally, \eqref{eq:plus_lower_bound_fu} follows from the casewise formula \eqref{eq:plus_sign_structure}.
\end{proof}

\subsection{Global well-posedness in \texorpdfstring{$L^2$}{L2}}
\label{subsec:plus_mild_wp}

Let \(S(\tau):=e^{\tau\Delta}\) be the heat semigroup on \(L^2(\mathbb{R}^d)\). A solution of \eqref{eq:plus_semilinear_heat} is a function
\[
u\in C([0,\infty);L^2(\mathbb{R}^d))
\]
satisfying the Duhamel formula \eqref{eq:duhamel_H1} with $f(u)=f_+(u),$ namely
\begin{equation}
u(\tau)=S(\tau)u_0-\int_0^\tau S(\tau-s)\,f_+(u(s))\,ds.
\label{eq:plus_duhamel}
\end{equation}

\begin{corollary}[Global well-posedness in \(L^2\) for the plus model]
\label{cor:plus_global_wp_L2}
For every \(u_0\in L^2(\mathbb{R}^d)\), the Cauchy problem \eqref{eq:plus_semilinear_heat}-\eqref{eq:plus_nonlinearity} admits a unique global mild solution
\[
u\in C([0,\infty);L^2(\mathbb{R}^d)).
\]
Moreover, the data-to-solution map is Lipschitz continuous on bounded time intervals.
\end{corollary}

\begin{proof}
By Lemma~\ref{lem:plus_basic_properties}, \(f_+\) is globally Lipschitz and satisfies \(f_+(0)=0\). Theorem~\ref{thm:L2_global_wp} therefore applies directly to \eqref{eq:plus_semilinear_heat}, yielding the stated global mild solution and Lipschitz dependence on the initial datum.
\end{proof}

\subsection{\texorpdfstring{$L^2$}{L2} a priori bound via Gr\"onwall}
\label{subsec:plus_L2_bound}

We next derive the correct \(L^2\) estimate for the non-dissipative model. Unlike the dissipative case, one does not obtain decay.

\begin{proposition}[\(L^2\) bound for the non-dissipative model]
\label{prop:plus_L2_gronwall}
Let \(u\) be a sufficiently smooth solution of \eqref{eq:plus_semilinear_heat}. Then
\begin{equation}
\frac12\frac{d}{d\tau}\|u(\tau)\|_{L^2}^2
+\|\nabla u(\tau)\|_{L^2}^2
+\int_{\mathbb{R}^d} f_+(u(\tau,z))\,u(\tau,z)\,dz
=0.
\label{eq:plus_L2_identity}
\end{equation}
Consequently,
\begin{equation}
\frac12\frac{d}{d\tau}\|u(\tau)\|_{L^2}^2
\le b\,\|u(\tau)\|_{L^2}^2,
\label{eq:plus_L2_diffineq}
\end{equation}
and therefore
\begin{equation}
\boxed{
\|u(\tau)\|_{L^2}^2 \le e^{2b\tau}\,\|u_0\|_{L^2}^2,
\qquad \tau\ge 0.
}
\label{eq:plus_L2_gronwall}
\end{equation}
\end{proposition}

\begin{proof}
Multiplying \eqref{eq:plus_semilinear_heat} by \(u\), integrating over \(\mathbb{R}^d\), and integrating by parts yields \eqref{eq:plus_L2_identity}. Using \eqref{eq:plus_lower_bound_fu}, we obtain
\[
\int_{\mathbb{R}^d} f_+(u)\,u\,dz \ge -b\int_{\mathbb{R}^d}|u|^2\,dz = -b\|u\|_{L^2}^2.
\]
Substituting into \eqref{eq:plus_L2_identity} gives
\[
\frac12\frac{d}{d\tau}\|u(\tau)\|_{L^2}^2 + \|\nabla u(\tau)\|_{L^2}^2 - b\|u(\tau)\|_{L^2}^2 \le 0,
\]
hence
\[
\frac12\frac{d}{d\tau}\|u(\tau)\|_{L^2}^2 \le b\|u(\tau)\|_{L^2}^2.
\]
Gronwall's lemma yields \eqref{eq:plus_L2_gronwall}.
\end{proof}

\begin{remark}[Interpretation of the estimate]
\label{rem:plus_no_decay}
Estimate \eqref{eq:plus_L2_gronwall} gives at most exponential control on finite time intervals. In particular, it does not imply decay as \(\tau\to\infty\). The nonlinearity \(f_+\) is therefore well posed in \(L^2\), but not dissipative in the sense of the energy method used for the model \(f_-\).
\end{remark}

\subsection{Instantaneous \texorpdfstring{$H^1$}{H1} regularization}
\label{subsec:plus_H1_regularization}

Even though the sign-coercive energy method fails, the parabolic smoothing effect remains available.

\begin{proposition}[Instantaneous \(H^1\) regularization]
\label{prop:plus_H1_smoothing}
Let \(u_0\in L^2(\mathbb{R}^d)\), and let \(u\) be the mild solution given by Corollary~\ref{cor:plus_global_wp_L2}. Then for every \(\tau>0\),
\[
u(\tau)\in H^1(\mathbb{R}^d),
\]
and
\begin{equation}
\|\nabla u(\tau)\|_{L^2}
\le C\,\tau^{-1/2}\|u_0\|_{L^2}
+ C L\int_0^\tau (\tau-s)^{-1/2} e^{bs}\|u_0\|_{L^2}\,ds.
\label{eq:plus_H1_smoothing_explicit}
\end{equation}
Hence \(u(\tau)\in H^1(\mathbb{R}^d)\) for every \(\tau>0\).
\end{proposition}

\begin{proof}
Differentiate the Duhamel formula \eqref{eq:plus_duhamel}:
\[
\nabla u(\tau)=\nabla S(\tau)u_0-\int_0^\tau \nabla S(\tau-s)f_+(u(s))\,ds.
\]
Taking \(L^2\)-norms and using the heat semigroup estimate
\[
\|\nabla S(t)\varphi\|_{L^2} \le C t^{-1/2}\|\varphi\|_{L^2}
\qquad (t>0),
\]
together with the bound \eqref{eq:plus_L2_gronwall} we achieve from
\[
\|f_+(u(s))\|_{L^2}\le L\|u(s)\|_{L^2}\le L e^{bs}\|u_0\|_{L^2},
\]
Then the estimate \eqref{eq:plus_H1_smoothing_explicit} readily follows from \eqref{eq:H1_smoothing_explicit}.
\end{proof}

\begin{remark}
The smoothing estimate above is sufficient to show that the plus-model solution becomes \(H^1\) for every positive time. However, unlike in the dissipative case, one does not obtain a monotone \(H^1\) energy inequality from the sign of the nonlinear term.
\end{remark}

\subsection{\texorpdfstring{$H^1$}{H1} well-posedness for the plus model}
\label{subsec:plus_H1_wp}

The sign-agnostic $H^1$ theory from Theorem~\ref{thm:H1_piecewise_wp} already covers the plus model; we record the specialization only for convenience.

\begin{corollary}[$H^1$ well-posedness for the plus model]
\label{cor:plus_H1_wp}
Let $u_0 \in H^1(\mathbb{R}^d)$. Then \eqref{eq:plus_semilinear_heat} admits a unique global mild solution
\[
u \in C([0,\infty); H^1(\mathbb{R}^d))
\]
and the data-to-solution map is Lipschitz continuous on bounded time intervals: for any two initial data $u_0, v_0 \in H^1(\mathbb{R}^d)$ and corresponding solutions $u, v$,
\[
\|u(\tau) - v(\tau)\|_{H^1}
\le e^{\sqrt{2}\max(a,b)\tau}\|u_0 - v_0\|_{H^1},
\qquad \tau \ge 0.
\]
\end{corollary}

\begin{proof}
Apply Theorem~\ref{thm:H1_piecewise_wp} with $f = f_+$; see also Remark~\ref{rem:H1_sign_agnostic}.
\end{proof}





\subsection{A Gagliardo-Nirenberg estimate with exponential weight}
\label{subsec:plus_GN}



We now show that the usual Gagliardo-Nirenberg argument may still be applied, but with an exponentially weighted quantity instead of a decaying one. More precisely we have

\begin{proposition}[Gagliardo-Nirenberg estimate for the plus model]
\label{prop:plus_GN}
Let \(u\) be a sufficiently regular solution of \eqref{eq:plus_semilinear_heat} with
\(
u_0\in L^1(\mathbb{R}^d)\cap L^2(\mathbb{R}^d).
\)
Then
\begin{equation}
\boxed{
\|u(\tau)\|_{L^2}^2
\le
e^{2b\tau}
\left(
\|u_0\|_{L^2}^{-4/d}
+
\frac{4}{d\,C_N}\|u_0\|_{L^1}^{-4/d}\tau
\right)^{-d/2},
}
\label{eq:plus_GN_final}
\end{equation}
where \(C_N\) is the constant in the Gagliardo-Nirenberg inequality
\[
\|\varphi\|_{L^2}^{2+4/d}
\le C_N \|\nabla \varphi\|_{L^2}^2 \|\varphi\|_{L^1}^{4/d}.
\]
In particular,
\begin{equation}
\|u(\tau)\|_{L^2}^2 \lesssim e^{2b\tau}\|u_0\|_{L^1}^2\,\tau^{-d/2}
\qquad (\tau\to\infty).
\label{eq:plus_GN_asymptotic}
\end{equation}
\end{proposition}

\begin{proof}

Assume now the Cauchy problem on $\R^d$ with initial datum
\[
\tilde u_0\in L^1(\R^d)\cap L^2(\R^d),
\]
and let
\[
f(s)=a\,s^+ + b\,s^-,
\qquad a,b\ge 0,
\qquad s^+=\max(s,0),\ \ s^-=\max(-s,0).
\]

We first recall the Gagliardo-Nirenberg inequality: there exists a constant
$C_N=C_N(d)>0$ such that for every
$\varphi\in H^1(\R^d)\cap L^1(\R^d)$,
\begin{equation}
\|\varphi\|_{L^2}^{2+\frac{4}{d}}
\le C_N\,\|\nabla \varphi\|_{L^2}^2\,\|\varphi\|_{L^1}^{\frac{4}{d}}.
\label{eq:GN_piecewise}
\end{equation}

\medskip
\noindent\textbf{Step 1: exponentially weighted \(L^1\) estimate.}
For the finance nonlinearity \(f_+\), one does not have \(L^1\)-contraction in general. Instead, one uses Kato's inequality in the distributional sense:
\[
\partial_\tau | u|-\Delta | u|
\le \operatorname{sign}( u)\bigl(\partial_\tau \ u-\Delta \ u\bigr).
\]
Since
\[
\partial_\tau  u-\Delta \ u=-f_+(\ u),
\]
we obtain
\[
\partial_\tau | u|-\Delta | u|
\le -\,\operatorname{sign}( u)\,f_+( u).
\]
Now, by cases,
\[
-\operatorname{sign}(s)\,f_+(s)
=
\begin{cases}
-a s=-a|s| \le b|s|, & s>0,\\[1mm]
0, & s=0,\\[1mm]
-(-1)\,b(-s)=b|s|, & s<0.
\end{cases}
\]
Hence
\[
-\operatorname{sign}(s)\,f_+(s)\le b|s|
\qquad\text{for all }s\in\R,
\]
and therefore
\begin{equation}
\partial_\tau |\tilde u|-\Delta |\tilde u|\le b\,|\tilde u|
\qquad\text{in }\mathcal D'((0,\infty)\times\R^d).
\label{eq:kato_finance_piecewise}
\end{equation}

Define
\[
v(\tau,z):=e^{-b\tau}|\tilde u(\tau,z)|.
\]
Then
\[
\partial_\tau v-\Delta v
=
e^{-b\tau}\bigl(\partial_\tau |\tilde u|-\Delta |\tilde u|-b|\tilde u|\bigr)
\le 0.
\]
Thus \(v\) is subcaloric. Integrating over \(\R^d\) (for instance by localization with cutoffs and letting the cutoff radius tend to infinity), one finds that
\[
\frac{d}{d\tau}\|v(\tau)\|_{L^1(\R^d)}\le 0.
\]
Since \(v(0,\cdot)=|\tilde u_0|\), this gives
\begin{equation}
\boxed{
\|\tilde u(\tau)\|_{L^1(\R^d)}
\le e^{b\tau}\,\|\tilde u_0\|_{L^1(\R^d)},
\qquad \tau\ge 0.
}
\label{eq:L1_finance_piecewise}
\end{equation}

\medskip
\noindent\textbf{Step 2: \(L^2\)-energy identity and lower bound on the reaction term.}
Set
\[
y(\tau):=\|\tilde u(\tau)\|_{L^2}^2.
\]
From the \(L^2\)-energy identity,
\[
\frac12 y'(\tau)
=
-\|\nabla \tilde u(\tau)\|_{L^2}^2
-\int_{\R^d} f_+(\tilde u(\tau,z))\,\tilde u(\tau,z)\,dz.
\]
Now
\[
f_+(s)s
=
\begin{cases}
a s^2 = a(s^+)^2, & s>0,\\[1mm]
0, & s=0,\\[1mm]
b(-s)s=-b s^2=-b(s^-)^2, & s<0,
\end{cases}
\]
hence
\begin{equation}
f_+(s)s=a(s^+)^2-b(s^-)^2\ge -b|s|^2.
\label{eq:finance_piecewise_fs}
\end{equation}
Therefore
\[
\int_{\R^d} f_+(\tilde u)\tilde u\,dz
\ge -b\int_{\R^d}|\tilde u|^2\,dz
=-b\,y(\tau),
\]
and so
\[
\frac12 y'(\tau)\le -\|\nabla \tilde u(\tau)\|_{L^2}^2+b\,y(\tau).
\]
Equivalently,
\begin{equation}
y'(\tau)\le -2\|\nabla \tilde u(\tau)\|_{L^2}^2+2b\,y(\tau).
\label{eq:yprime_finance_piecewise}
\end{equation}

\medskip
\noindent\textbf{Step 3: insert the Gagliardo-Nirenberg lower bound.}
By \eqref{eq:GN} and \eqref{eq:L1_finance_piecewise},
\[
\|\nabla \tilde u(\tau)\|_{L^2}^2
\ge
\frac{1}{C_N}\,
\frac{\|\tilde u(\tau)\|_{L^2}^{2+\frac{4}{d}}}{\|\tilde u(\tau)\|_{L^1}^{\frac{4}{d}}}
\ge
\frac{1}{C_N}\,
\frac{y(\tau)^{1+\frac{2}{d}}}{\bigl(e^{b\tau}\|\tilde u_0\|_{L^1}\bigr)^{\frac{4}{d}}}.
\]
Thus
\[
\|\nabla \tilde u(\tau)\|_{L^2}^2
\ge
\frac{1}{C_N}\,
e^{-\frac{4b}{d}\tau}\,
\|\tilde u_0\|_{L^1}^{-\frac{4}{d}}\,
y(\tau)^{1+\frac{2}{d}}.
\]
Substituting into \eqref{eq:yprime_finance_piecewise}, we obtain
\begin{equation}
y'(\tau)
\le
-\frac{2}{C_N}\,
e^{-\frac{4b}{d}\tau}\,
\|\tilde u_0\|_{L^1}^{-\frac{4}{d}}\,
y(\tau)^{1+\frac{2}{d}}
+2b\,y(\tau).
\label{eq:finance_piecewise_ode}
\end{equation}

\medskip
\noindent\textbf{Step 4: exponentially weighted \(L^2\) quantity.}
Define
\[
z(\tau):=e^{-2b\tau}y(\tau).
\]
Then
\[
z'(\tau)=e^{-2b\tau}\bigl(y'(\tau)-2b\,y(\tau)\bigr).
\]
Using \eqref{eq:finance_piecewise_ode}, we obtain
\[
z'(\tau)
\le
-\frac{2}{C_N}\,
e^{-2b\tau}\,
e^{-\frac{4b}{d}\tau}\,
\|\tilde u_0\|_{L^1}^{-\frac{4}{d}}\,
y(\tau)^{1+\frac{2}{d}}.
\]
Since
\[
y(\tau)=e^{2b\tau}z(\tau),
\]
we have
\[
y(\tau)^{1+\frac{2}{d}}
=
e^{2b\tau(1+\frac{2}{d})}z(\tau)^{1+\frac{2}{d}}.
\]
Hence
\[
e^{-2b\tau}e^{-\frac{4b}{d}\tau}y(\tau)^{1+\frac{2}{d}}
=
e^{-2b\tau}e^{-\frac{4b}{d}\tau}
e^{2b\tau(1+\frac{2}{d})}
z(\tau)^{1+\frac{2}{d}}
=
z(\tau)^{1+\frac{2}{d}}.
\]
Therefore
\begin{equation}
z'(\tau)
\le
-\frac{2}{C_N}\,
\|\tilde u_0\|_{L^1}^{-\frac{4}{d}}\,
z(\tau)^{1+\frac{2}{d}}.
\label{eq:z_finance_piecewise}
\end{equation}

\medskip
\noindent\textbf{Step 5: solve the differential inequality.}
Let
\(
\beta:=\frac{2}{d}.
\)
Then
\[
\frac{d}{d\tau}\bigl(z(\tau)^{-\beta}\bigr)
=
-\beta\,z(\tau)^{-(1+\beta)}z'(\tau)
\ge
\beta\,\frac{2}{C_N}\,\|\tilde u_0\|_{L^1}^{-\frac{4}{d}}.
\]
Integrating from \(0\) to \(\tau\) gives
\[
z(\tau)^{-\beta}
\ge
z(0)^{-\beta}
+
\frac{4}{d\,C_N}\,\|\tilde u_0\|_{L^1}^{-\frac{4}{d}}\tau.
\]
Since
\[
z(0)=y(0)=\|\tilde u_0\|_{L^2}^2,
\]
we infer
\[
z(\tau)
\le
\Bigl(
\|\tilde u_0\|_{L^2}^{-\frac{4}{d}}
+
\frac{4}{d\,C_N}\,\|\tilde u_0\|_{L^1}^{-\frac{4}{d}}\tau
\Bigr)^{-\frac{d}{2}}.
\]
Recalling that \(y(\tau)=e^{2b\tau}z(\tau)\), we conclude
\begin{equation}
\boxed{
\|\tilde u(\tau)\|_{L^2}^2
=
y(\tau)
\le
e^{2b\tau}
\Bigl(
\|\tilde u_0\|_{L^2}^{-\frac{4}{d}}
+
\frac{4}{d\,C_N}\,\|\tilde u_0\|_{L^1}^{-\frac{4}{d}}\tau
\Bigr)^{-\frac{d}{2}}.
}
\label{eq:finance_piecewise_final}
\end{equation}
In particular,
\begin{equation}
\boxed{
\|\tilde u(\tau)\|_{L^2}^2
\lesssim
e^{2b\tau}\,\|\tilde u_0\|_{L^1}^2\,\tau^{-d/2},
\qquad \tau\to\infty.
}
\label{eq:finance_piecewise_asymp}
\end{equation}



\end{proof}










