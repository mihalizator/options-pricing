\subsection{Mathematical background}
\subsubsection{A linear-algebra fact for symmetric positive definite matrices}

The whitening step used in the reduction of the nonlinear Black-Scholes
equation to a semilinear heat equation relies on the standard Cholesky
factorization for symmetric positive definite matrices.

\begin{proposition}[Cholesky factorization for symmetric positive definite matrices]
\label{prop:cholesky_spd}
Let $A\in\mathbb R^{d\times d}$ be symmetric positive definite. Then there
exists an invertible lower triangular matrix $R$ with positive diagonal entries
such that
\[
A = RR^\top.
\]
In particular, if $Q\in\mathbb R^{d\times d}$ is symmetric positive definite,
then $\frac12 Q$ is also symmetric positive definite, so there exists an
invertible matrix $L$ such that
\[
LL^\top = \frac12 Q.
\]
\end{proposition}



To study diffusion and parabolic equations rigorously, we require several standard notions from functional analysis, particularly those concerning function spaces on $\mathbb{R}^n$ and on bounded domains $\Omega \subset \mathbb{R}^n$.
This section records the functional-analytic background used repeatedly in the thesis, especially for $L^p$ and Sobolev spaces, weak derivatives, distributions, and Fourier analysis; standard references include Evans \cite{EvansPDE} and Br\'ezis \cite{Brezis2011}.

\subsubsection{Metric and Normed Spaces}

\begin{definition}[Metric Space]
A \emph{metric space} is a set $X$ together with a function
\[
d : X \times X \to \mathbb{R},
\]
called a \emph{metric} (or \emph{distance function}), satisfying for all $x, y, z \in X$:
\begin{enumerate}
    \item $d(x, y) \ge 0$ and $d(x, y) = 0$ if and only if $x = y$, \hfill (non-negativity and identity)
    \item $d(x, y) = d(y, x)$, \hfill (symmetry)
    \item $d(x, z) \le d(x, y) + d(y, z)$. \hfill (triangle inequality)
\end{enumerate}
\end{definition}

\begin{definition}[Normed Vector Space]
A \emph{normed vector space} is a vector space $X$ over $\mathbb{C}$ (or $\mathbb{R}$) equipped with a function
\[
\|\cdot\| : X \to \mathbb{R},
\]
called a \emph{norm}, satisfying for all $x, y \in X$ and all scalars $\alpha \in \mathbb{C}$:
\begin{enumerate}
    \item $\|x\| \ge 0$ and $\|x\| = 0$ if and only if $x = 0$, \hfill (positive definiteness)
    \item $\|\alpha x\| = |\alpha|\,\|x\|$, \hfill (homogeneity)
    \item $\|x + y\| \le \|x\| + \|y\|$. \hfill (triangle inequality)
\end{enumerate}
\end{definition}

Every normed vector space $(X, \|\cdot\|)$ induces a metric via
\[
d(x, y) = \|x - y\|, \quad x, y \in X.
\]

\begin{definition}[Inner Product Space]
An \emph{inner product space} is a vector space $X$ over $\mathbb{C}$ endowed with a function
\[
\langle \cdot, \cdot \rangle : X \times X \to \mathbb{C},
\]
called an \emph{inner product}, satisfying for all $x, y, x_1, x_2, y_1, y_2 \in X$ and $a, b \in \mathbb{C}$:
\begin{enumerate}
    \item $\langle x, x \rangle \ge 0$ and $\langle x, x \rangle = 0$ iff $x = 0$, \hfill (positive definiteness)
    \item $\langle x, y \rangle = \overline{\langle y, x \rangle}$, \hfill (conjugate symmetry)
    \item $\langle a x_1 + b x_2, y \rangle = a \langle x_1, y \rangle + b \langle x_2, y \rangle$, \hfill (linearity in the first argument)
    \item $\langle x, a y_1 + b y_2 \rangle = \overline{a}\,\langle x, y_1 \rangle + \overline{b}\,\langle x, y_2 \rangle$. \hfill (conjugate linearity)
\end{enumerate}
The associated norm is given by $\|x\| = \sqrt{\langle x, x \rangle}$.
\end{definition}

\begin{definition}[Cauchy and Convergent Sequences]
Let $(X, d)$ be a metric space.
\begin{itemize}
    \item A sequence $(x_n)$ is \emph{Cauchy} if for every $\varepsilon > 0$ there exists $N \in \mathbb{N}$ such that
    $d(x_m, x_n) < \varepsilon$ for all $m, n \ge N$.
    \item A sequence $(x_n)$ \emph{converges} to $x \in X$ if for every $\varepsilon > 0$ there exists $N \in \mathbb{N}$ such that
    $d(x_n, x) < \varepsilon$ for all $n \ge N$.
\end{itemize}
\end{definition}

\begin{definition}[Complete Normed Space]
A normed vector space $X$ is \emph{complete} if every Cauchy sequence in $X$ converges to a limit in $X$.
\end{definition}

A complete normed space is a \emph{Banach space}, while a complete inner product space is a \emph{Hilbert space}.

\begin{theorem}[Banach fixed-point theorem]
\label{thm:banach_fixed_point}
Let $(X,d)$ be a complete metric space, and let $T:X\to X$ satisfy
\[
d(Tx,Ty)\le k\,d(x,y)
\qquad \text{for all } x,y\in X,
\]
for some constant $k\in[0,1)$. Then $T$ has a unique fixed point $x_*\in X$.
Moreover, for every starting point $x_0\in X$, the iterates defined by
\[
x_{n+1}=Tx_n,
\qquad n\ge 0,
\]
converge to $x_*$.
\end{theorem}

\begin{proof}
Fix $x_0\in X$ and define the sequence $(x_n)$ by $x_{n+1}=Tx_n$.
Since $T$ is a contraction,
\[
d(x_{n+1},x_n)=d(Tx_n,Tx_{n-1})\le k\,d(x_n,x_{n-1})
\qquad \text{for } n\ge 1.
\]
By induction this gives
\[
d(x_{n+1},x_n)\le k^n d(x_1,x_0)
\qquad \text{for all } n\ge 0.
\]

Now let $m>n$. By the triangle inequality,
\[
d(x_m,x_n)
\le \sum_{j=n}^{m-1} d(x_{j+1},x_j)
\le d(x_1,x_0)\sum_{j=n}^{m-1} k^j.
\]
Since $0\le k<1$, the geometric-series formula yields
\[
d(x_m,x_n)
\le d(x_1,x_0)\,\frac{k^n-k^m}{1-k}
\le \frac{k^n}{1-k}\,d(x_1,x_0).
\]
The right-hand side tends to $0$ as $n\to\infty$, uniformly in $m>n$, so
$(x_n)$ is a Cauchy sequence. Because $X$ is complete, there exists
$x_*\in X$ such that $x_n\to x_*$.

It remains to show that $x_*$ is a fixed point. Using again that $T$ is a
contraction,
\[
d(Tx_*,x_*)
\le d(Tx_*,Tx_n)+d(Tx_n,x_*)
\le k\,d(x_*,x_n)+d(x_{n+1},x_*).
\]
Letting $n\to\infty$ gives $d(Tx_*,x_*)=0$, hence $Tx_*=x_*$.

To prove uniqueness, suppose $y_*\in X$ is another fixed point of $T$.
Then
\[
d(x_*,y_*)=d(Tx_*,Ty_*)\le k\,d(x_*,y_*).
\]
Therefore $(1-k)d(x_*,y_*)\le 0$. Since $1-k>0$ and distances are
nonnegative, it follows that $d(x_*,y_*)=0$, so $x_*=y_*$. Thus the fixed
point is unique, and the iteration from any initial point converges to it.
\end{proof}

\begin{definition}[Dense Subset]
Let $(X, d)$ be a metric space. A subset $A \subset X$ is said to be \emph{dense} in $X$ if for every
$x \in X$ and every $\varepsilon > 0$ there exists $a \in A$ such that
\[
d(x, a) < \varepsilon.
\]
Equivalently, $A$ is dense in $X$ if the closure of $A$ equals $X$, that is,
\[
\overline{A} = X.
\]
\end{definition}

\subsubsection{Spaces of Continuous Functions}

Let $\Omega \subset \mathbb{R}^n$ be an open or bounded domain. We collect several function spaces that frequently arise in the study of parabolic and elliptic PDEs.

\begin{definition}[$C(\Omega)$]
The space $C(\Omega)$ consists of all real- or complex-valued functions
\[
f : \Omega \to \mathbb{C}
\]
that are continuous at every point of $\Omega$.
\end{definition}

\begin{definition}[$C_b(\Omega)$]
The space $C_b(\Omega)$ denotes the set of continuous functions on $\Omega$ that are \emph{bounded}, i.e.,
\[
\|f\|_\infty := \sup_{x \in \Omega} |f(x)| < \infty.
\]
Equipped with the uniform norm $\|\cdot\|_\infty$, the space $C_b(\Omega)$ is a Banach space.
\end{definition}

\begin{definition}[$C_c(\Omega)$]
The space $C_c(\Omega)$ consists of continuous functions whose support is compact and contained in $\Omega$:
\[
C_c(\Omega) := \{f \in C(\Omega) : \operatorname{supp}(f) \subset\subset \Omega\}.
\]
This space is dense in many important function spaces, including $L^p(\Omega)$ for $1 \le p < \infty$.
\end{definition}

\begin{definition}[$C^k(\Omega)$]
For an integer $k \ge 1$, the space $C^k(\Omega)$ consists of functions whose partial derivatives of all orders up to $k$ exist and are continuous on $\Omega$.
We equip $C^k(\Omega)$ with the norm
\[
\|f\|_{C^k} := \sum_{|\alpha| \le k} \sup_{x \in \Omega} |D^\alpha f(x)|.
\]
\end{definition}

\begin{definition}[$C^\infty(\Omega)$]
The space $C^\infty(\Omega)$ consists of functions that are infinitely differentiable on $\Omega$.
\end{definition}

\begin{definition}[$C_c^\infty(\Omega)$ - Test Functions]
The space $C_c^\infty(\Omega)$ consists of smooth functions with compact support in $\Omega$.
\end{definition}



\subsection{Lebesgue Spaces \texorpdfstring{$L^p$}{Lp}}

Lebesgue spaces are among the most important examples of Banach spaces, forming the basis of modern analysis and PDE theory.

\begin{definition}[Lebesgue Space]
Let $\Omega \subset \mathbb{R}^n$ be a measurable domain with a positive measure $\mu$, and let $p > 0$.
Under the convention that functions equal almost everywhere are identified, the \emph{Lebesgue space} $L^p(\Omega)$ is defined as
\[
L^p(\Omega) = \left\{ f \text{ measurable on } \Omega :
\|f\|_{L^p(\Omega)} = \left( \int_{\Omega} |f(x)|^p \, d\mu(x) \right)^{1/p} < \infty \right\}.
\]
For $p = \infty$, $L^\infty(\Omega)$ consists of all measurable, essentially bounded functions with
\[
\|f\|_{L^\infty(\Omega)} = \operatorname*{ess\,sup}_{x \in \Omega} |f(x)| < \infty.
\]
\end{definition}

\begin{definition}[Lebesgue Conjugate]
For $p \in [1, \infty]$, the \emph{conjugate exponent} $p'$ is defined by
\[
\frac{1}{p} + \frac{1}{p'} = 1, \qquad
\text{that is,} \quad
p' =
\begin{cases}
\dfrac{p}{p-1}, & 1 < p < \infty, \\[0.5em]
\infty, & p = 1.
\end{cases}
\]
\end{definition}

\begin{remark}
The space $L^2(\Omega)$ is a Hilbert space with inner product
\[
\langle f, g \rangle = \int_{\Omega} f(x)\,\overline{g(x)}\,dx,
\]
and corresponding norm $\|f\|_{L^2(\Omega)} = \sqrt{\langle f, f \rangle}$.
\end{remark}



\begin{theorem}[Hölder's Inequality]
Let $1 \le p, q \le \infty$ satisfy $\frac{1}{p} + \frac{1}{q} = 1$.
Then for all $f \in L^p(\Omega)$ and $g \in L^q(\Omega)$,
\[
\int_{\Omega} |f(x)g(x)| \, d\mu(x)
\le \|f\|_{L^p(\Omega)} \, \|g\|_{L^q(\Omega)}.
\]
\end{theorem}

\begin{theorem}[Minkowski's Inequality]
Let $1 \le p \le \infty$ and $f, g \in L^p(\Omega)$. Then
\[
\|f + g\|_{L^p(\Omega)} \le \|f\|_{L^p(\Omega)} + \|g\|_{L^p(\Omega)}.
\]
\end{theorem}

\begin{theorem}[Gronwall's Inequality]
Let $T>0$, let $u:[0,T]\to[0,\infty)$ be continuous, and let
$\alpha\in L^1(0,T)$ and $\beta\in L^1(0,T)$ with $\beta\ge 0$ almost everywhere.
If
\[
u(t) \le \alpha(t) + \int_0^t \beta(s)\,u(s)\,ds,
\qquad 0\le t\le T,
\]
then
\[
u(t) \le \alpha(t) + \int_0^t \alpha(s)\,\beta(s)
\exp\!\left(\int_s^t \beta(r)\,dr\right) ds,
\qquad 0\le t\le T.
\]
In particular, if $\alpha(t)\equiv C\ge 0$, then
\[
u(t) \le C\exp\!\left(\int_0^t \beta(s)\,ds\right),
\qquad 0\le t\le T.
\]
\end{theorem}

\begin{proof}
Define $v(t) := \int_0^t \beta(s)\,u(s)\,ds$, so that $v(0)=0$ and
\[
    v'(t) = \beta(t)\,u(t) \le \beta(t)\,\alpha(t) + \beta(t)\,v(t)
    \quad \text{  on }(0,T).
\]
Multiplying by the integrating factor
$\mu(t) := \exp\!\left(-\int_0^t \beta(r)\,dr\right)$ gives
\[
    \frac{d}{dt}\bigl[\mu(t)\,v(t)\bigr] \le \mu(t)\,\alpha(t)\,\beta(t)
    \quad \text{  on }(0,T).
\]
Integrating from $0$ to $t$ and using $v(0)=0$, we obtain
\[
    \mu(t)\,v(t) \le \int_0^t \mu(s)\,\alpha(s)\,\beta(s)\,ds.
\]
Hence
\[
    v(t) \le \frac{1}{\mu(t)}\int_0^t \mu(s)\,\alpha(s)\,\beta(s)\,ds
    = \int_0^t \alpha(s)\,\beta(s)\exp\!\left(\int_s^t \beta(r)\,dr\right)\,ds.
\]
Substituting this into $u(t) \le \alpha(t) + v(t)$ yields
\[
    u(t) \le \alpha(t) + \int_0^t \alpha(s)\,\beta(s)
    \exp\!\left(\int_s^t \beta(r)\,dr\right)\,ds,
\]
which is exactly the stated bound. In the special case $\alpha(t)\equiv C$, this reduces to
\[
    u(t) \le C\exp\!\left(\int_0^t \beta(s)\,ds\right).
\]
\end{proof}




\begin{remark}
For $\alpha, \beta > 0$ and measurable $f$, the Lebesgue norms satisfy
\[
\|f^{\alpha}\|_{L^{\beta}(\Omega)}
= \left( \int_{\Omega} |f|^{\alpha \beta} \, dx \right)^{1/\beta}
= \|f\|_{L^{\alpha \beta}(\Omega)}^{\alpha}.
\]
\end{remark}



\begin{theorem}
\label{thm:Cc-in-Lp}
$C_c^\infty(\Omega)$ is dense in $L^p(\Omega)$ for every $1 \le p < \infty$.
\end{theorem}

A standard proof combines truncation, approximation by continuous compactly supported functions, and mollification; see, for instance, Evans \cite{EvansPDE} or Br\'ezis \cite{Brezis2011}.

\begin{comment}
\begin{proposition}
Let $u$ be a bounded function with compact support. If $u$ is Riemann
integrable, then $u$ is also Lebesgue integrable, and its Riemann integral
coincides with its Lebesgue integral.
\end{proposition}
\end{comment}


\subsubsection{Sobolev Spaces \texorpdfstring{\(W^{k,p}\)}{Wk,p}}

Another fundamental class of Banach spaces is formed by the \emph{Sobolev spaces}, which play a central role in the analysis of partial differential equations; see Evans \cite{EvansPDE} and Br\'ezis \cite{Brezis2011}.

\begin{definition}[Sobolev Space]
Let $\Omega \subset \mathbb{R}^n$ be an open domain.
For an integer $k \in \mathbb{N}$ and $1 \le p \le \infty$, the \emph{Sobolev space} $W^{k,p}(\Omega)$ is defined as the set of all locally integrable functions $f : \Omega \to \mathbb{R}$ such that for every multi-index $\alpha$ with $|\alpha| \le k$, the weak derivative $\partial_x^{\alpha} f$ exists and belongs to $L^p(\Omega)$.
The norm is given by
\[
\|u\|_{W^{k,p}(\Omega)} =
\begin{cases}
\left( \displaystyle\sum_{|\alpha|\le k} \int_{\Omega} |\partial_x^{\alpha} u|^p \, dx \right)^{1/p}, & 1 \le p < \infty, \\[1em]
\displaystyle\sum_{|\alpha|\le k} \operatorname*{ess\,sup}_{x \in \Omega} |\partial_x^{\alpha} u(x)|, & p = \infty.
\end{cases}
\]
\end{definition}

\begin{definition}[Homogeneous Sobolev Space]
The \emph{homogeneous Sobolev space}, denoted $\dot{W}^{k,p}(\Omega)$, is defined as the space of functions for which all weak derivatives of order exactly $k$ belong to $L^p(\Omega)$, with norm
\[
\|u\|_{\dot{W}^{k,p}(\Omega)} =
\begin{cases}
\left( \displaystyle\int_{\Omega} |\nabla^k u|^p \, dx \right)^{1/p}, & 1 \le p < \infty, \\[1em]
\operatorname*{ess\,sup}_{x \in \Omega} |\nabla^k u(x)|, & p = \infty.
\end{cases}
\]
\end{definition}

\begin{remark}
If $p = 2$, the Sobolev space $W^{k,2}(\Omega)$ is a Hilbert space, and it is customary to write
\[
H^k(\Omega) = W^{k,2}(\Omega),
\qquad
\dot{H}^k(\Omega) = \dot{W}^{k,2}(\Omega),
\qquad
H^0(\Omega) = \dot{H}^0(\Omega) = L^2(\Omega).
\]
\end{remark}

\begin{proposition}[Sobolev truncation]
\label{prop:sobolev_truncation}
Let $1 \le p < \infty$, let $u \in W^{1,p}(\R^n)$, and let
$\Phi:\R\to\R$ be Lipschitz with $\Phi(0)=0$. Then $\Phi\circ u \in W^{1,p}(\R^n)$ and
\[
\nabla(\Phi\circ u)=\Phi'(u)\,\nabla u
\qquad\text{  in }\R^n,
\]
where $\Phi'$ is understood at points of differentiability of $\Phi$, which
exist almost everywhere. In particular,
\[
u^+ := \max(u,0),
\qquad
u^- := \max(-u,0)
\]
belong to $W^{1,p}(\R^n)$, and
\[
\nabla u^+ = \mathbf{1}_{\{u>0\}}\,\nabla u,
\qquad
\nabla u^- = -\mathbf{1}_{\{u<0\}}\,\nabla u
\qquad\text{  in }\R^n.
\]
\end{proposition}

\begin{proof}
Choose a sequence $(u_k)\subset C^\infty(\R^n)\cap W^{1,p}(\R^n)$ such that
$u_k\to u$ in $W^{1,p}(\R^n)$; for example, one may obtain such an approximation by a standard density and mollification argument. Since $\Phi$ is Lipschitz and $\Phi(0)=0$,
we have $|\Phi(s)|\le \operatorname{Lip}(\Phi)\,|s|$, hence
$\Phi(u_k)\to \Phi(u)$ in $L^p(\R^n)$. For smooth $u_k$, the classical chain
rule gives
\[
\nabla(\Phi(u_k))=\Phi'(u_k)\,\nabla u_k
\qquad\text{  in }\R^n.
\]
Since $|\Phi'|\le \operatorname{Lip}(\Phi)$ almost everywhere, the gradients
are bounded in $L^p(\R^n)$; passing to the limit in the weak derivative
identity yields $\Phi(u)\in W^{1,p}(\R^n)$ with the stated gradient formula.

For $\Phi(s)=s^+$ and $\Phi(s)=s^-$, one has $\Phi'(s)=\mathbf{1}_{\{s>0\}}$
and $\Phi'(s)=-\mathbf{1}_{\{s<0\}}$ for almost every $s\in\R$, which gives
the formulas for $\nabla u^+$ and $\nabla u^-$.
\end{proof}



\subsubsection{Inequalities}

We record the inequalities used later, especially the Gagliardo-Nirenberg interpolation estimate.






\begin{theorem}[Young's Inequality]
Let $p, q \in (1, \infty)$ with $\dfrac{1}{p} + \dfrac{1}{q} = 1$. Then for all
$a, b \geq 0$,
\begin{equation}
    ab \leq \frac{a^p}{p} + \frac{b^q}{q}.
\end{equation}
Equality holds if and only if $a^p = b^q$.
\end{theorem}


\begin{theorem}[Gagliardo-Nirenberg Inequality]
Let $1 \le q \le \infty$, let $j,m\in\mathbb{N}_0$ with $j<m$, and let
$1\le r\le \infty$, $p\ge 1$, and $\theta\in[0,1]$ satisfy
\[
\frac{1}{p}=\frac{j}{n}+\theta\!\left(\frac{1}{r}-\frac{m}{n}\right)+\frac{1-\theta}{q},
\qquad
\frac{j}{m}\le \theta\le 1.
\]
Then there exists a constant $C>0$, depending only on
$j,m,n,q,r,\theta$, such that
\[
\|D^j u\|_{L^p(\mathbb{R}^n)}
\le
C\,\|D^m u\|_{L^r(\mathbb{R}^n)}^{\theta}
\,\|u\|_{L^q(\mathbb{R}^n)}^{1-\theta}
\]
for every $u\in L^q(\mathbb{R}^n)$ with $D^m u\in L^r(\mathbb{R}^n)$.

\end{theorem}

\subsection{Distributions and weak derivatives}
\label{app:distributions}

Let $\Omega \subseteq \mathbb{R}^n$ be open.
We denote by $C_0^\infty(\Omega)=C_c^\infty(\Omega)$ the space of infinitely differentiable functions with compact support in $\Omega$. The basic notions recalled here are standard; see Evans \cite{EvansPDE} and Br\'ezis \cite{Brezis2011}.

\begin{definition}[Distributions]
The space of \emph{distributions} on $\Omega$, denoted $\mathcal{D}'(\Omega)$, is the space of all continuous linear functionals
\[
u : C_0^\infty(\Omega) \to \mathbb{R}, \qquad
\varphi \mapsto \langle u, \varphi \rangle.
\]
For $f \in L^1_{\mathrm{loc}}(\Omega)$, the map
\[
\langle f, \varphi \rangle = \int_{\Omega} f(x)\varphi(x)\,dx
\]
defines a \emph{regular distribution}.
\end{definition}

\begin{definition}[Distributional Derivative]
For $u \in \mathcal{D}'(\Omega)$ and a multi-index $\alpha$, the \emph{distributional derivative} $\partial_x^{\alpha} u$ is defined by
\[
\langle \partial_x^{\alpha} u, \varphi \rangle
= (-1)^{|\alpha|} \langle u, \partial_x^{\alpha} \varphi \rangle,
\qquad \forall \varphi \in C_0^\infty(\Omega).
\]
\end{definition}

\begin{definition}[Convergence in the Sense of Distributions]
A sequence $(u_n) \subset \mathcal{D}'(\Omega)$ is said to \emph{converge to} $u \in \mathcal{D}'(\Omega)$ \emph{in the sense of distributions} if and only if
\[
\langle u_n, \varphi \rangle \longrightarrow \langle u, \varphi \rangle
\quad \text{for every } \varphi \in C_0^\infty(\Omega).
\]
Equivalently, $u_n \xrightarrow{\mathcal{D}'(\Omega)} u$ in the weak-$*$ topology induced by $C_0^\infty(\Omega)$.
\end{definition}

\subsubsection{Fourier transform and the Schwartz space}

In the analysis of the heat equation and related parabolic PDEs, the natural starting point for the Fourier transform is the Schwartz space. This choice avoids integrability and differentiability issues, since Schwartz functions are smooth and decay faster than any power at infinity, together with all of their derivatives; see, for example, Evans \cite{EvansPDE} and Br\'ezis \cite{Brezis2011}.

\begin{definition}[Rapidly decreasing function]
Let $\langle x\rangle := (1+|x|^2)^{1/2}$ for $x\in\mathbb R^n$.
A function $f:\mathbb R^n\to\mathbb C$ is said to be \emph{rapidly decreasing} if
\[
\sup_{x\in\mathbb R^n} \langle x\rangle^N |f(x)| < \infty
\qquad \text{for every } N\ge 0.
\]
\end{definition}

\begin{definition}[Schwartz space]
The \emph{Schwartz space} $\mathcal S(\mathbb R^n)$ is the set of all functions
$f\in C^\infty(\mathbb R^n)$ such that for every pair of multi-indices
$\alpha,\beta\in\mathbb N_0^n$,
\[
\sup_{x\in\mathbb R^n} |x^\alpha \partial^\beta f(x)| < \infty.
\]
Equivalently, every derivative of $f$ is rapidly decreasing.
\end{definition}

\noindent
Here, for $\alpha=(\alpha_1,\dots,\alpha_n)$ and $\beta=(\beta_1,\dots,\beta_n)$, we use the standard multi-index notation
\[
x^\alpha = x_1^{\alpha_1}\cdots x_n^{\alpha_n},
\qquad
\partial^\beta
=
\partial_{x_1}^{\beta_1}\cdots \partial_{x_n}^{\beta_n}.
\]

\begin{definition}[Fourier transform on $\mathcal S(\mathbb R^n)$]
For $f\in\mathcal S(\mathbb R^n)$, its \emph{Fourier transform} is defined by
\begin{equation}
\widehat f(\xi)
:=
\mathcal Ff(\xi)
=
\int_{\mathbb R^n} f(x)\,e^{-ix\cdot \xi}\,dx,
\qquad \xi\in\mathbb R^n.
\label{eq:fourier_transform_schwartz}
\end{equation}
\end{definition}

This integral is absolutely convergent for every $\xi\in\mathbb R^n$, since $f\in\mathcal S(\mathbb R^n)\subset L^1(\mathbb R^n)$.
Moreover, one may differentiate under the integral sign, and repeated integration by parts is justified because all derivatives of $f$ decay rapidly. As a consequence, $\widehat f$ is again a Schwartz function.

\begin{proposition}[Invariance of the Schwartz space]
If $f\in\mathcal S(\mathbb R^n)$, then $\widehat f\in\mathcal S(\mathbb R^n)$.
Moreover, the inverse transform is given by
\begin{equation}
f(x)=\frac{1}{(2\pi)^n}\int_{\mathbb R^n}\widehat f(\xi)\,e^{ix\cdot\xi}\,d\xi,
\qquad x\in\mathbb R^n.
\label{eq:inverse_fourier_schwartz}
\end{equation}
Hence $\mathcal F:\mathcal S(\mathbb R^n)\to\mathcal S(\mathbb R^n)$ is a bijection.
\end{proposition}

\begin{proof}[Idea of the proof]
Since $f\in\mathcal S(\mathbb R^n)$, the integral \eqref{eq:fourier_transform_schwartz} is absolutely convergent. Differentiating with respect to $\xi$ gives
\[
\partial_\xi^\alpha \widehat f(\xi)
=
\int_{\mathbb R^n} (-ix)^\alpha f(x)e^{-ix\cdot\xi}\,dx,
\]
which is again well defined because $x^\alpha f(x)\in L^1(\mathbb R^n)$.
On the other hand, multiplying by powers of $\xi$ corresponds, after integration by parts, to differentiating $f$:
\[
\xi^\beta \widehat f(\xi)
=
\mathcal F\bigl[(i\partial_x)^\beta f\bigr](\xi)
\]
up to harmless sign conventions. Since every derivative $\partial^\beta f$ also belongs to $\mathcal S(\mathbb R^n)$, all seminorms
\[
\sup_{\xi\in\mathbb R^n} |\xi^\beta \partial_\xi^\alpha \widehat f(\xi)|
\]
are finite, proving that $\widehat f\in\mathcal S(\mathbb R^n)$.
The inversion formula \eqref{eq:inverse_fourier_schwartz} is standard on $\mathcal S(\mathbb R^n)$.
\end{proof}

\begin{remark}[Why $\mathcal S(\mathbb R^n)$ is the natural starting point]
The Schwartz space is the ideal class for Fourier analysis in PDEs:
\begin{itemize}
\item functions and all derivatives decay rapidly, so the Fourier integral is absolutely convergent;
\item differentiation under the integral sign is justified;
\item integration by parts produces no boundary terms at infinity;
\item the Fourier transform preserves the class $\mathcal S(\mathbb R^n)$.
\end{itemize}
For these reasons, Fourier identities are first proved on $\mathcal S(\mathbb R^n)$ and then extended, by density or duality, to larger spaces such as $L^2(\mathbb R^n)$ and the space of tempered distributions $\mathcal S'(\mathbb R^n)$.
\end{remark}


\subsubsection{Distributional inequalities}

\begin{theorem}[Kato's Inequality]
Let $u \in L^1_{\mathrm{loc}}(\Omega)$, where $\Omega \subseteq \mathbb{R}^n$ is an open
set, and suppose that $\Delta u \in L^1_{\mathrm{loc}}(\Omega)$ in the sense of
distributions. Then
\begin{equation}
    \Delta |u| \geq \operatorname{Re}\!\left(\operatorname{sgn}(u)\, \Delta u\right)
    \quad \text{in } \mathcal{D}'(\Omega),
\end{equation}
where $\operatorname{sgn}(u)(x) = \overline{u(x)}/|u(x)|$ for $u(x) \neq 0$ and $0$
otherwise. Equivalently, for any non-negative test function
$\varphi \in C_c^\infty(\Omega)$,
\begin{equation}
    \int_\Omega |u|\, \Delta\varphi \, dx
    \geq \int_\Omega \operatorname{Re}\!\left(\operatorname{sgn}(u)\, \Delta u\right)
    \varphi \, dx.
\end{equation}
\end{theorem}

\begin{remark}
In the real-valued case, the inequality reduces to
\begin{equation}
    \Delta |u| \geq \operatorname{sgn}(u)\, \Delta u \quad \text{in } \mathcal{D}'(\Omega).
\end{equation}
\end{remark}

\begin{proposition}[Parabolic Kato inequality]
Let $\Omega\subseteq\mathbb{R}^n$ be open, $T>0$, and set
$Q=\Omega\times(0,T)$. Suppose
$u\in L^1_{\mathrm{loc}}(Q)$ with
$\partial_t u,\,\nabla u,\,\Delta u\in L^1_{\mathrm{loc}}(Q)$.
Then
\[
  \partial_t|u|-\Delta|u|
  \;\le\;
  \operatorname{sign}(u)\!\left(\partial_t u-\Delta u\right)
  \quad\text{in }\mathcal{D}'(Q),
\]
\end{proposition}


\begin{proof}
For \(\varepsilon>0\), define
\[
\Phi_\varepsilon(s):=\sqrt{s^2+\varepsilon^2},
\qquad
\phi_\varepsilon(s):=\Phi_\varepsilon'(s)=\frac{s}{\sqrt{s^2+\varepsilon^2}}.
\]
Then \(\Phi_\varepsilon\in C^\infty(\mathbb R)\) and
\[
\Phi_\varepsilon''(s)=\phi_\varepsilon'(s)=\frac{\varepsilon^2}{(s^2+\varepsilon^2)^{3/2}}\ge 0.
\]
By the chain rule,
\[
\partial_t \Phi_\varepsilon(u)=\phi_\varepsilon(u)\partial_t u,
\]
and
\[
\Delta \Phi_\varepsilon(u)
=
\phi_\varepsilon(u)\Delta u+\phi_\varepsilon'(u)|\nabla u|^2.
\]
Therefore
\[
\partial_t \Phi_\varepsilon(u)-\Delta \Phi_\varepsilon(u)
=
\phi_\varepsilon(u)\bigl(\partial_t u-\Delta u\bigr)
-\phi_\varepsilon'(u)|\nabla u|^2
\le
\phi_\varepsilon(u)\bigl(\partial_t u-\Delta u\bigr).
\]
Testing against a nonnegative \(\psi\in C_c^\infty(Q)\) and letting \(\varepsilon\downarrow 0\), using
\[
\Phi_\varepsilon(u)\to |u|,
\qquad
\phi_\varepsilon(u)\to \operatorname{sign}(u),
\qquad
|\phi_\varepsilon(u)|\le 1,
\]
yields\footnote{By convergence theorems.}
\[
\partial_t |u|-\Delta |u|
\le
\operatorname{sign}(u)\bigl(\partial_t u-\Delta u\bigr)
\qquad\text{in }\mathcal D'(Q).
\]
\end{proof}

\begin{remark}[Extension to $L^2$ and tempered distributions]
The Fourier transform extends uniquely from $\mathcal S(\mathbb R^n)$ to a unitary operator on $L^2(\mathbb R^n)$ (up to the normalization convention). It also extends by duality to the space of tempered distributions $\mathcal S'(\mathbb R^n)$, defined by
\[
\langle \widehat T,\varphi\rangle := \langle T,\widehat\varphi\rangle,
\qquad \varphi\in\mathcal S(\mathbb R^n).
\]
This is the framework used when Fourier methods are applied to weak solutions and fundamental solutions of PDEs.
\end{remark}







